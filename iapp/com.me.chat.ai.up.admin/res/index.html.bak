            renderMessage('assistant', aiMsg, true);
            State.history.push({ role: "user", content: `(漂流瓶系统: 玩家捡到并回复了漂流瓶)` });
            State.history.push({ role: "assistant", content: aiMsg });
        }
        
        // ================= 管理员日记系统 (AI生成) =================
        const DiarySystem = {
            // 获取已保存的日记列表
            getDiaries: function() {
                try {
                    return JSON.parse(localStorage.getItem('7723_diaries')) || [];
                } catch(e) { return []; }
            },
            
            saveDiaries: function(diaries) {
                localStorage.setItem('7723_diaries', JSON.stringify(diaries));
            },
            
            getLastDiaryDate: function() {
                return localStorage.getItem('7723_last_diary_date') || '';
            },
            
            // 获取昨天的日期字符串
            getYesterdayKey: function() {
                const d = new Date();
                d.setDate(d.getDate() - 1);
                return d.toDateString();
            },
            
            getTodayKey: function() {
                return new Date().toDateString();
            },
            
            // 从聊天历史中提取昨天的对话
            getYesterdayHistory: function() {
                // 保存历史时附带日期标记
                try {
                    const dated = JSON.parse(localStorage.getItem('7723_dated_history')) || {};
                    const yesterdayKey = this.getYesterdayKey();
                    return dated[yesterdayKey] || [];
                } catch(e) { return []; }
            },
            
            // 保存当天的对话快照（每次对话后调用）
            saveTodayHistory: function() {
                try {
                    const dated = JSON.parse(localStorage.getItem('7723_dated_history')) || {};
                    const todayKey = this.getTodayKey();
                    // 保存最近的对话（最多20条）
                    dated[todayKey] = State.history.slice(-20);
                    // 只保留最近3天的记录，避免localStorage膨胀
                    const keys = Object.keys(dated);
                    if (keys.length > 3) {
                        keys.sort();
                        keys.slice(0, keys.length - 3).forEach(k => delete dated[k]);
                    }
                    localStorage.setItem('7723_dated_history', JSON.stringify(dated));
                } catch(e) { console.error('保存每日对话失败', e); }
            },
            
            // 每天第一次运行时调用AI生成日记
            checkAndGenerateDiary: async function() {
                const today = this.getTodayKey();
                if (this.getLastDiaryDate() === today) return; // 今天已经生成过了
                
                const yesterdayHistory = this.getYesterdayHistory();
                if (yesterdayHistory.length === 0) {
                    // 没有昨天的对话记录，标记今天已检查，不生成
                    localStorage.setItem('7723_last_diary_date', today);
                    return;
                }
                
                // 格式化昨天的对话
                const formatted = yesterdayHistory.map(msg => {
                    const role = msg.role === 'user' ? '玩家' : '管理员';
                    return `${role}: ${msg.content}`;
                }).join('\n');
                
                const diaryPrompt = `你是一个Galgame的【日记生成器】，请站在"萌娘管理员"的角度写一篇私密日记。

【昨天的对话记录】
${formatted}

【要求】
1. 用第一人称"我"来写，语气是傲娇萌娘风格（偶尔用颜文字）
2. 回顾昨天和玩家的对话，写下管理员的内心感受
3. 可以是开心、害羞、生气、感动等任何真实反应
4. 字数控制在50-120字之间
5. 不要提及"日记"这个词，就像在自言自语
6. 根据日记内容的隐私程度和情感深度，设定一个"偷看价格"(信誉分)，范围5-50：
   - 普通日常感想：5-15分
   - 有点害羞的内容：15-30分
   - 很私密/很心动的内容：30-50分

【输出格式】
只返回纯JSON，不要Markdown标记：
{"title": "日记标题(4字以内)", "content": "日记正文", "icon": "一个合适的emoji", "cost": 数字(5-50)}`;

                try {
                    const res = await fetch(CONFIG.api.url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${CONFIG.api.key}` },
                        body: JSON.stringify({
                            model: State.optionModel,
                            messages: [{ role: "user", content: diaryPrompt }],
                            temperature: 0.8,
                            stream: false
                        })
                    });
                    
                    if (!res.ok) throw new Error(`HTTP ${res.status}`);
                    
                    const data = await res.json();
                    const raw = data.choices[0].message.content;
                    
                    let entry;
                    try {
                        entry = extractJSON(raw, false);
                    } catch(e) {
                        entry = { title: '碎碎念', content: raw.substring(0, 120), icon: '📝', cost: 10 };
                    }
                    
                    // 保存日记
                    const diaries = this.getDiaries();
                    const yesterday = new Date();
                    yesterday.setDate(yesterday.getDate() - 1);
                    const cost = Math.max(5, Math.min(50, parseInt(entry.cost) || 10));
                    diaries.push({
                        date: `${yesterday.getMonth()+1}月${yesterday.getDate()}日`,
                        title: entry.title || '碎碎念',
                        content: entry.content || '今天什么也没发生...',
                        icon: entry.icon || '📝',
                        cost: cost,
                        unlocked: false,
                        timestamp: yesterday.getTime()
                    });
                    
                    // 最多保存30篇日记
                    if (diaries.length > 30) diaries.shift();
                    
                    this.saveDiaries(diaries);
                    localStorage.setItem('7723_last_diary_date', today);
                    
                    // 弹出提示
                    showToast('📔 管理员写了新的日记~', 'bg-amber-500');
                    
                } catch(e) {
                    console.error('日记生成失败', e);
                    localStorage.setItem('7723_last_diary_date', today);
                }
            }
        };
        
        function toggleDiary() {
            const modal = document.getElementById('diary-modal');
            const list = document.getElementById('diary-entries');
            
            if (modal.classList.contains('hidden')) {
                list.innerHTML = '';
                
                const diaries = DiarySystem.getDiaries();
                
                if (diaries.length === 0) {
                    list.innerHTML = '<div class="text-center py-12 text-amber-600/60 text-sm">还没有日记~<br>明天再来看看吧！<br><span class="text-xs text-gray-400 mt-2 block">管理员会根据每天的对话写日记</span></div>';
                } else {
                    // 从新到旧排列
                    [...diaries].reverse().forEach((entry, index) => {
                        const realIndex = diaries.length - 1 - index;
                        const isUnlocked = entry.unlocked === true;
                        const cost = entry.cost || 10;
                        const div = document.createElement('div');
                        
                        if (isUnlocked) {
                            div.className = 'mb-4 rounded-xl p-4 border-2 bg-white border-amber-300 shadow-md transition-all hover:shadow-lg cursor-pointer';
                            div.innerHTML = `
                                <div class="flex items-center gap-2 mb-2">
                                    <span class="text-xl">${entry.icon}</span>
                                    <div>
                                        <div class="text-xs text-amber-600 font-bold">${entry.date}</div>
                                        <div class="text-sm font-bold text-amber-900">${entry.title}</div>
                                    </div>
                                </div>
                                <div class="relative">
                                    <p class="text-sm leading-relaxed text-gray-700 italic">
                                        "${entry.content}"
                                    </p>
                                </div>
                            `;
                            div.onclick = () => {
                                toggleDiary();
                                changeLove(1);
                                renderMessage('user', `[日记] 偷看了管理员的日记："${entry.title}"`);
                                const aiMsg = `你...你居然偷看我的日记！！笨蛋！！💢😳`;
                                renderMessage('assistant', aiMsg, true);
                                State.history.push({ role: "user", content: `(日记系统: 玩家翻看了"${entry.title}"，管理员发现了)` });
                                State.history.push({ role: "assistant", content: aiMsg });
                                State.currentExpression = 'shy';
                                updateMoodUI('shy');
                                showMoodToast('shy');
                            };
                        } else {
                            div.className = 'mb-4 rounded-xl p-4 border-2 bg-gray-50 border-gray-200 shadow-sm transition-all';
                            div.innerHTML = `
                                <div class="flex items-center gap-2 mb-2">
                                    <span class="text-xl">🔒</span>
                                    <div class="flex-1">
                                        <div class="text-xs text-gray-400 font-bold">${entry.date}</div>
                                        <div class="text-sm font-bold text-gray-400">${entry.title}</div>
                                    </div>
                                    <button onclick="unlockDiary(${realIndex})" class="px-3 py-1.5 bg-amber-500 text-white text-xs font-bold rounded-lg hover:bg-amber-600 transition-colors shadow-sm">
                                        🔑 ${cost}分解锁
                                    </button>
                                </div>
                                <div class="relative">
                                    <p class="text-sm leading-relaxed text-gray-300 select-none" style="filter: blur(5px);">
                                        "${entry.content}"
                                    </p>
                                </div>
                            `;
                        }
                        
                        list.appendChild(div);
                    });
                }
                
                // 日记总数和解锁统计
                const unlockedCount = diaries.filter(d => d.unlocked === true).length;
                const progressDiv = document.createElement('div');
                progressDiv.className = 'text-center py-3 text-xs text-amber-600';
                progressDiv.textContent = `共 ${diaries.length} 篇日记 | 已解锁 ${unlockedCount} 篇 | 信誉分: ${State.score}`;
                list.insertBefore(progressDiv, list.firstChild);
                
                modal.classList.remove('hidden');
                modal.classList.add('flex');
                toggleMenu();
            } else {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }
        }
        
        function unlockDiary(index) {
            const diaries = DiarySystem.getDiaries();
            if (index < 0 || index >= diaries.length) return;
            
            const entry = diaries[index];
            if (entry.unlocked) return;
            
            const cost = entry.cost || 10;
            if (State.score < cost) {
                showToast(`信誉分不足！需要${cost}分`, 'bg-red-500');
                return;
            }
            
            changeScore(-cost);
            entry.unlocked = true;
            DiarySystem.saveDiaries(diaries);
            
            showToast(`🔓 解锁了"${entry.title}" -${cost}分`, 'bg-amber-500');
            SFX.play('success');
            
            // 刷新日记列表
            const modal = document.getElementById('diary-modal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            toggleDiary();
        }
        
        // ================= 今日占卜系统 (AI生成) =================
        function toggleFortune() {
            const modal = document.getElementById('fortune-modal');
            if (modal.classList.contains('hidden')) {
                // 检查今天是否已占卜
                const today = new Date().toDateString();
                const lastFortune = localStorage.getItem('7723_last_fortune_date');
                if (lastFortune === today) {
                    // 显示已有结果
                    try {
                        const saved = JSON.parse(localStorage.getItem('7723_fortune_result'));
                        if (saved) showFortuneResult(saved);
                    } catch(e) {}
                    document.getElementById('fortune-card').style.display = 'none';
                    document.getElementById('fortune-cooldown').textContent = '今日已占卜，明天再来~';
                } else {
                    document.getElementById('fortune-card').style.display = 'flex';
                    document.getElementById('fortune-result').classList.add('hidden');
                    document.getElementById('fortune-cooldown').textContent = '';
                }
                modal.classList.remove('hidden');
                modal.classList.add('flex');
                toggleMenu();
            } else {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }
        }
        
        async function drawFortune() {
            if (State.score < 15) {
                showToast('信誉分不足！需要15分', 'bg-red-500');
                return;
            }
            
            changeScore(-15);
            
            const card = document.getElementById('fortune-card');
            card.style.transform = 'rotateY(180deg) scale(0.8)';
            card.style.opacity = '0';
            card.style.pointerEvents = 'none';
            
            const fortunePrompt = `你是一个Galgame的【占卜系统】，请站在"萌娘管理员"的角度为玩家进行今日运势占卜。

【当前状态】
- 好感度: ${State.love}
- 信誉分: ${State.score}
- 当前心情: ${State.currentExpression}

【要求】
1. 用傲娇萌娘语气写占卜结果
2. 包含：总运势、恋爱运、幸运建议
3. 内容有趣，偶尔调侃玩家
4. 字数50-100字

【输出格式】
只返回纯JSON：
{"icon": "一个代表运势的emoji", "title": "运势等级(如:大吉/中吉/小吉/凶)", "content": "占卜内容", "love_hint": "恋爱运提示(10字以内)", "lucky_item": "今日幸运物(5字以内)"}`;

            try {
                const res = await fetch(CONFIG.api.url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${CONFIG.api.key}` },
                    body: JSON.stringify({
                        model: State.optionModel,
                        messages: [{ role: "user", content: fortunePrompt }],
                        temperature: 0.9,
                        stream: false
                    })
                });
                
                if (!res.ok) throw new Error(`HTTP ${res.status}`);
                const data = await res.json();
                const raw = data.choices[0].message.content;
                
                let result;
                try {
                    result = extractJSON(raw, false);
                } catch(e) {
                    result = { icon: '🔮', title: '中吉', content: '今天运气还不错哦~', love_hint: '保持微笑', lucky_item: '冰可乐' };
                }
                
                localStorage.setItem('7723_last_fortune_date', new Date().toDateString());
                localStorage.setItem('7723_fortune_result', JSON.stringify(result));
                
                showFortuneResult(result);
                
                changeLove(1);
                renderMessage('assistant', `[占卜] ${result.icon} ${result.title}！${result.content}`, true);
                State.history.push({ role: "assistant", content: `(占卜系统: ${result.title} - ${result.content})` });
                
            } catch(e) {
                console.error('占卜失败', e);
                showToast('占卜水晶球碎了...', 'bg-red-500');
                changeScore(15); // 退回
            }
            
            setTimeout(() => {
                card.style.display = 'none';
                document.getElementById('fortune-cooldown').textContent = '今日已占卜，明天再来~';
            }, 500);
        }
        
        function showFortuneResult(result) {
            document.getElementById('fortune-icon').textContent = result.icon || '🔮';
            document.getElementById('fortune-title').textContent = result.title || '中吉';
            document.getElementById('fortune-content').textContent = result.content || '';
            document.getElementById('fortune-love').textContent = `💕 ${result.love_hint || ''}`;
            document.getElementById('fortune-luck').textContent = `🍀 ${result.lucky_item || ''}`;
            document.getElementById('fortune-advice').textContent = `✨ AI占卜`;
            document.getElementById('fortune-result').classList.remove('hidden');
        }
        
        // ================= 真心话大冒险系统 =================
        const TruthDare = {
            maxPerDay: 5,
            getTodayKey: function() { return 'td_' + new Date().toDateString(); },
            getTodayCount: function() {
                return parseInt(localStorage.getItem(this.getTodayKey())) || 0;
            },
            incrementCount: function() {
                const count = this.getTodayCount() + 1;
                localStorage.setItem(this.getTodayKey(), count);
                return count;
            },
            currentType: null,
            currentQuestion: null
        };
        
        function toggleTruthDare() {
            const modal = document.getElementById('truthdare-modal');
            if (modal.classList.contains('hidden')) {
                resetTruthDare();
                document.getElementById('td-count').textContent = TruthDare.getTodayCount();
                modal.classList.remove('hidden');
                modal.classList.add('flex');
                toggleMenu();
            } else {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }
        }
        
        function resetTruthDare() {
            document.getElementById('td-choice-area').classList.remove('hidden');
            document.getElementById('td-question-area').classList.add('hidden');
            document.getElementById('td-result-area').classList.add('hidden');
            document.getElementById('td-options').innerHTML = '';
            TruthDare.currentType = null;
            TruthDare.currentQuestion = null;
        }
        
        async function startTruthDare(type) {
            if (TruthDare.getTodayCount() >= TruthDare.maxPerDay) {
                showToast('今天玩够了~明天再来！', 'bg-yellow-500');
                return;
            }
            if (State.score < 20) {
                showToast('信誉分不足！需要20分', 'bg-red-500');
                return;
            }
            
            changeScore(-20);
            TruthDare.currentType = type;
            
            document.getElementById('td-choice-area').classList.add('hidden');
            document.getElementById('td-question-area').classList.remove('hidden');
            document.getElementById('td-result-area').classList.add('hidden');
            document.getElementById('td-type-label').textContent = type === 'truth' ? '💬 真心话' : '🔥 大冒险';
            document.getElementById('td-question-text').textContent = '管理员正在想问题...';
            document.getElementById('td-options').innerHTML = '<div class="text-center text-xs text-gray-400">AI正在生成选项...</div>';
            
            const tdPrompt = type === 'truth' ? 
                `你是一个傲娇萌娘管理员，正在和玩家玩真心话大冒险。玩家选了"真心话"。
请生成一个有趣的问题，以及3个供玩家选择的回答选项（风格各异：认真/搞笑/暧昧）。
当前好感度: ${State.love}（好感越高问题可以越大胆/暧昧）。
同时为每个选项生成管理员的反应。
只返回纯JSON：{"question": "问题(20-40字)", "emoji": "emoji", "options": [{"text": "选项1(15字以内)", "reaction": "管理员反应(20字以内)", "mood": "shy或happy或angry"}, {"text": "选项2", "reaction": "反应", "mood": "心情"}, {"text": "选项3", "reaction": "反应", "mood": "心情"}]}` :
                `你是一个傲娇萌娘管理员，正在和玩家玩真心话大冒险。玩家选了"大冒险"。
请生成一个有趣的挑战，以及3个玩家可以选择的应对方式（风格各异：勇敢/投机/浪漫）。
当前好感度: ${State.love}（好感越高挑战可以越大胆）。
同时为每个选项生成管理员的反应。
只返回纯JSON：{"question": "挑战(20-40字)", "emoji": "emoji", "options": [{"text": "选项1(15字以内)", "reaction": "管理员反应(20字以内)", "mood": "shy或happy或angry"}, {"text": "选项2", "reaction": "反应", "mood": "心情"}, {"text": "选项3", "reaction": "反应", "mood": "心情"}]}`;
            
            try {
                const res = await fetch(CONFIG.api.url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${CONFIG.api.key}` },
                    body: JSON.stringify({
                        model: State.optionModel,
                        messages: [{ role: "user", content: tdPrompt }],
                        temperature: 0.9,
                        stream: false
                    })
                });
                
                if (!res.ok) throw new Error(`HTTP ${res.status}`);
                const data = await res.json();
                const raw = data.choices[0].message.content;
                
                let parsed;
                try { parsed = extractJSON(raw, false); }
                catch(e) {
                    parsed = {
                        question: type === 'truth' ? '你最喜欢管理员哪一点？' : '在聊天里夸管理员一句',
                        emoji: '🎤',
                        options: [
                            { text: '你的笑容最好看', reaction: '哈？突然说这种话...笨蛋！', mood: 'shy' },
                            { text: '你傲娇的样子', reaction: '才、才没有傲娇！', mood: 'angry' },
                            { text: '全部都喜欢♡', reaction: '...你这人真是的...', mood: 'shy' }
                        ]
                    };
                }
                
                TruthDare.currentQuestion = parsed.question;
                document.getElementById('td-question-text').textContent = `${parsed.emoji || '🎤'} ${parsed.question}`;
                
                // 渲染AI生成的选项按钮
                const optionsDiv = document.getElementById('td-options');
                optionsDiv.innerHTML = '';
                const options = parsed.options || [];
                if (options.length === 0) {
                    options.push({ text: '好的！', reaction: '嗯...还算有诚意吧', mood: 'happy' });
                }
                options.forEach((opt, i) => {
                    const btn = document.createElement('button');
                    const colors = ['bg-pink-50 border-pink-300 text-pink-700 hover:bg-pink-100', 'bg-blue-50 border-blue-300 text-blue-700 hover:bg-blue-100', 'bg-purple-50 border-purple-300 text-purple-700 hover:bg-purple-100'];
                    btn.className = `w-full p-3 rounded-xl text-sm font-bold transition-all border-2 ${colors[i % 3]}`;
                    btn.textContent = opt.text;
                    btn.onclick = () => selectTruthDareOption(opt);
                    optionsDiv.appendChild(btn);
                });
                
            } catch(e) {
                console.error('真心话大冒险生成失败', e);
                const fallbackQ = type === 'truth' ? '你最喜欢管理员哪一点？' : '在聊天里说一句"管理员最可爱了"';
                TruthDare.currentQuestion = fallbackQ;
                document.getElementById('td-question-text').textContent = `🎤 ${fallbackQ}`;
                const optionsDiv = document.getElementById('td-options');
                optionsDiv.innerHTML = '';
                [
                    { text: '你太可爱了！', reaction: '哈？才不是可爱！', mood: 'shy' },
                    { text: '嗯...让我想想', reaction: '想什么想，快回答！', mood: 'angry' },
                    { text: '我全都喜欢♡', reaction: '...笨蛋', mood: 'shy' }
                ].forEach((opt, i) => {
                    const btn = document.createElement('button');
                    const colors = ['bg-pink-50 border-pink-300 text-pink-700 hover:bg-pink-100', 'bg-blue-50 border-blue-300 text-blue-700 hover:bg-blue-100', 'bg-purple-50 border-purple-300 text-purple-700 hover:bg-purple-100'];
                    btn.className = `w-full p-3 rounded-xl text-sm font-bold transition-all border-2 ${colors[i % 3]}`;
                    btn.textContent = opt.text;
                    btn.onclick = () => selectTruthDareOption(opt);
                    optionsDiv.appendChild(btn);
                });
            }
        }
        
        function selectTruthDareOption(opt) {
            const count = TruthDare.incrementCount();
            document.getElementById('td-count').textContent = count;
            
            changeLove(2);
            changeScore(10);
            
            document.getElementById('td-question-area').classList.add('hidden');
            document.getElementById('td-result-area').classList.remove('hidden');
            
            const moodEmoji = opt.mood === 'shy' ? '😳' : opt.mood === 'angry' ? '😤' : '😊';
            document.getElementById('td-result-icon').textContent = moodEmoji;
            document.getElementById('td-result-text').textContent = `${opt.reaction} (好感+2，信誉分+10)`;
            
            SFX.play('success');
            
            const typeLabel = TruthDare.currentType === 'truth' ? '真心话' : '大冒险';
            renderMessage('user', `[${typeLabel}] ${opt.text}`);
            renderMessage('assistant', opt.reaction, true);
            State.history.push({ role: "user", content: `(真心话大冒险: 玩家选了${typeLabel}，问题"${TruthDare.currentQuestion}"，选择"${opt.text}")` });
            State.history.push({ role: "assistant", content: opt.reaction });
            
            const mood = opt.mood || 'shy';
            State.currentExpression = mood === 'angry' ? 'angry' : 'shy';
            updateMoodUI(State.currentExpression);
        }
        
        function skipTruthDare() {
            TruthDare.incrementCount();
            const count = TruthDare.getTodayCount();
            document.getElementById('td-count').textContent = count;
            
            changeLove(-1);
            
            document.getElementById('td-question-area').classList.add('hidden');
            document.getElementById('td-result-area').classList.remove('hidden');
            document.getElementById('td-result-icon').textContent = '😤';
            document.getElementById('td-result-text').textContent = '切，不敢回答就算了！好感-1';
            
            renderMessage('assistant', `哼！选了又不敢回答，胆小鬼！💢`, true);
            State.history.push({ role: "assistant", content: `(真心话大冒险: 玩家跳过了问题，管理员不高兴了)` });
        }
        
        // ================= 共养宠物系统 =================
        const PetSystem = {
            STAGES: [
                { name: '蛋', emoji: '🥚', expNeeded: 0 },
                { name: '幼崽', emoji: '🐣', expNeeded: 30 },
                { name: '成长', emoji: '🐥', expNeeded: 80 },
                { name: '少年', emoji: '🐱', expNeeded: 150 },
                { name: '成年', emoji: '🐈', expNeeded: 300 },
                { name: '王者', emoji: '👑🐈', expNeeded: 500 }
            ],
            
            getData: function() {
                try {
                    return JSON.parse(localStorage.getItem('7723_pet')) || {
                        name: '未命名',
                        hunger: 100,
                        mood: 100,
                        exp: 0,
                        lastUpdate: Date.now(),
                        lastFeed: 0,
                        lastPlay: 0
                    };
                } catch(e) {
                    return { name: '未命名', hunger: 100, mood: 100, exp: 0, lastUpdate: Date.now(), lastFeed: 0, lastPlay: 0 };
                }
            },
            
            saveData: function(data) {
                localStorage.setItem('7723_pet', JSON.stringify(data));
            },
            
            getStage: function(exp) {
                let stage = this.STAGES[0];
                for (let s of this.STAGES) {
                    if (exp >= s.expNeeded) stage = s;
                }
                return stage;
            },
            
            // 时间流逝：饱腹和心情缓慢下降
            updateDecay: function(data) {
                const now = Date.now();
                const hoursPassed = (now - data.lastUpdate) / 3600000;
                data.hunger = Math.max(0, data.hunger - Math.floor(hoursPassed * 3));
                data.mood = Math.max(0, data.mood - Math.floor(hoursPassed * 2));
                data.lastUpdate = now;
                return data;
            }
        };
        
        function togglePet() {
            const modal = document.getElementById('pet-modal');
            if (modal.classList.contains('hidden')) {
                updatePetUI();
                modal.classList.remove('hidden');
                modal.classList.add('flex');
                toggleMenu();
            } else {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }
        }
        
        function updatePetUI() {
            let data = PetSystem.getData();
            data = PetSystem.updateDecay(data);
            PetSystem.saveData(data);
            
            const stage = PetSystem.getStage(data.exp);
            document.getElementById('pet-emoji').textContent = stage.emoji;
            document.getElementById('pet-name').textContent = data.name;
            document.getElementById('pet-stage').textContent = `阶段: ${stage.name}`;
            document.getElementById('pet-hunger').textContent = data.hunger;
            document.getElementById('pet-mood').textContent = data.mood;
            document.getElementById('pet-exp').textContent = data.exp;
            
            // 状态文字
            let status = '';
            if (data.hunger < 20) status = '宠物好饿...快喂食！🥺';
            else if (data.mood < 20) status = '宠物不开心了...陪它玩吧 😢';
            else if (data.hunger >= 80 && data.mood >= 80) status = '宠物很开心！🎉';
            else status = '状态还不错~';
            document.getElementById('pet-status-text').textContent = status;
        }
        
        function feedPet() {
            if (State.score < 10) {
                showToast('信誉分不足！需要10分', 'bg-red-500');
                return;
            }
            
            let data = PetSystem.getData();
            data = PetSystem.updateDecay(data);
            
            if (data.hunger >= 100) {
                showToast('宠物已经吃饱了~', 'bg-yellow-500');
                return;
            }
            
            changeScore(-10);
            data.hunger = Math.min(100, data.hunger + 30);
            data.exp += 5;
            PetSystem.saveData(data);
            
            SFX.play('success');
            showToast('🍖 喂食成功！经验+5', 'bg-pink-500');
            updatePetUI();
            
            const stage = PetSystem.getStage(data.exp);
            renderMessage('assistant', `[宠物] ${data.name}开心地吃了起来~现在是${stage.name}阶段！`, true);
            State.history.push({ role: "assistant", content: `(宠物系统: 玩家喂食了宠物${data.name})` });
        }
        
        function playWithPet() {
            if (State.score < 5) {
                showToast('信誉分不足！需要5分', 'bg-red-500');
                return;
            }
            
            let data = PetSystem.getData();
            data = PetSystem.updateDecay(data);
            
            if (data.mood >= 100) {
                showToast('宠物已经很开心了~', 'bg-yellow-500');
                return;
            }
            
            changeScore(-5);
            data.mood = Math.min(100, data.mood + 25);
            data.exp += 3;
            PetSystem.saveData(data);
            
            SFX.play('success');
            showToast('🎾 玩耍成功！经验+3', 'bg-blue-500');
            updatePetUI();
            
            renderMessage('assistant', `[宠物] ${data.name}玩得好开心呀~要不...下次我们三个一起玩？😳`, true);
            State.history.push({ role: "assistant", content: `(宠物系统: 玩家和宠物${data.name}一起玩耍)` });
        }
        
        function petPet() {
            let data = PetSystem.getData();
            data = PetSystem.updateDecay(data);
            data.mood = Math.min(100, data.mood + 5);
            data.exp += 1;
            PetSystem.saveData(data);
            
            showToast('✋ 摸摸~经验+1', 'bg-amber-500');
            changeLove(1);
            updatePetUI();
        }
        
        function namePet() {
            const name = document.getElementById('pet-name-input').value.trim();
            if (!name) {
                showToast('请输入名字~', 'bg-yellow-500');
                return;
            }
            
            let data = PetSystem.getData();
            data.name = name;
            PetSystem.saveData(data);
            
            document.getElementById('pet-name-input').value = '';
            showToast(`宠物改名为"${name}"！`, 'bg-amber-500');
            updatePetUI();
            
            renderMessage('assistant', `[宠物] 我们的宠物叫"${name}"了！...等等，"我们的"？我才没有！哼！😤`, true);
            State.history.push({ role: "assistant", content: `(宠物系统: 玩家给宠物取名为${name})` });
        }
        
        window.onload = init;
        
        // V2.0 初始化
        setTimeout(() => {
            setupHeadpat();
            updateTitle();
        }, 1000);
    </script>
</body>
</html>
