        // 任务管理器
        const TaskManager = {
            loadTasks: function() {
                const saved = localStorage.getItem('7723_tasks');
                const lastReset = localStorage.getItem('7723_tasks_last_reset');
                const today = new Date().toDateString();
                
                if (saved && lastReset === today) {
                    try {
                        const savedData = JSON.parse(saved);
                        DAILY_TASKS.forEach(task => {
                            const savedTask = savedData.dailyTasks?.find(t => t.id === task.id);
                            if (savedTask) {
                                task.current = savedTask.current || 0;
                                task.completed = savedTask.completed || false;
                            }
                        });
                        
                        HIDDEN_ACHIEVEMENTS.forEach(ach => {
                            const savedAch = savedData.hiddenAchievements?.find(a => a.id === ach.id);
                            if (savedAch) {
                                ach.current = savedAch.current || 0;
                                ach.unlocked = savedAch.unlocked || false;
                            }
                        });
                    } catch (e) {
                        console.error('Failed to load daily tasks and achievements from localStorage. Using default values.', e);
                    }
                } else {
                    // 新的一天，重置每日任务
                    this.resetDailyTasks();
                    localStorage.setItem('7723_tasks_last_reset', today);
                }
            },

            saveTasks: function() {
                const toSave = {
                    dailyTasks: DAILY_TASKS.map(task => ({
                        id: task.id,
                        current: task.current,
                        completed: task.completed
                    })),
                    hiddenAchievements: HIDDEN_ACHIEVEMENTS.map(ach => ({
                        id: ach.id,
                        current: ach.current,
                        unlocked: ach.unlocked
                    }))
                };
                localStorage.setItem('7723_tasks', JSON.stringify(toSave));
            },

            resetDailyTasks: function() {
                DAILY_TASKS.forEach(task => {
                    task.current = 0;
                    task.completed = false;
                });
                this.saveTasks();
            },

            updateTaskProgress: function(taskId, amount = 1) {
                const task = DAILY_TASKS.find(t => t.id === taskId);
                if (task && !task.completed) {
                    task.current = Math.min(task.current + amount, task.target);
                    if (task.current >= task.target) {
                        task.completed = true;
                        this.giveReward(task.reward);
                        this.showTaskCompleteToast(task);
                    }
                    this.saveTasks();
                }
            },

            updateHiddenProgress: function(achId, amount = 1) {
                const ach = HIDDEN_ACHIEVEMENTS.find(a => a.id === achId);
