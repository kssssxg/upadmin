      // ================= TTS 语音模块 (带开关判断) =================
const TTS = {
    // 指向你服务器的 PHP 文件
    apiEndpoint: "http://192.140.173.130:3187/tts.php", 
    
    queue: [],
    isPlaying: false,
    audio: new Audio(),

    init: function() {
        // 解锁音频上下文
        const unlock = () => {
            this.audio.play().catch(() => {});
            this.audio.pause();
            document.body.removeEventListener('click', unlock);
        };
        document.body.addEventListener('click', unlock);

        this.audio.onended = () => {
            this.isPlaying = false;
            this.processQueue();
        };
        this.audio.onerror = (e) => {
            console.log("播放跳过:", e);
            this.isPlaying = false;
            this.processQueue();
        };
    },

    speak: function(text) {
        // 🔥【关键判断】如果开关没开，直接不读
        if (!State.isVoiceOn || !text) return;

        // 清洗文本
        let clean = text.replace(/<[^>]+>/g, '').replace(/\[.*?\]/g, '').trim();
        if (!clean) return;

        // 简单的标点断句
        const sentences = clean.split(/([。！？?!;；])/).reduce((acc, val, idx, arr) => {
             if (idx % 2 === 0 && val.trim()) acc.push(val + (arr[idx+1]||''));
             return acc;
        }, []);
        if(!sentences.length) sentences.push(clean);

        sentences.forEach(s => this.queue.push(s));
        this.processQueue();
    },

    processQueue: async function() {
        // 如果关了语音，清空队列并停止
        if (!State.isVoiceOn) {
            this.queue = [];
            return;
        }

        if (this.isPlaying || this.queue.length === 0) return;

        this.isPlaying = true;
        const txt = this.queue.shift();
        
        try {
            // 请求 PHP 获取静态文件链接
            const res = await fetch(`${this.apiEndpoint}?text=${encodeURIComponent(txt)}`);
            const wavUrl = await res.text();

            if (!wavUrl.startsWith('http')) throw new Error("TTS URL Error");

            this.audio.src = wavUrl;
            this.audio.playbackRate = 1.1; // 萌娘语速
            await this.audio.play();

        } catch (e) {
            console.error(e);
            this.isPlaying = false;
            this.processQueue();
        }
    }
};

// ================= 开关控制逻辑 =================
function toggleVoice() {
    State.isVoiceOn = !State.isVoiceOn;
    localStorage.setItem('7723_voice_on', State.isVoiceOn);
    updateVoiceUI();
    
    // 如果关闭了，立即停止当前语音
    if (!State.isVoiceOn) {
        TTS.audio.pause();
        TTS.queue = [];
        TTS.isPlaying = false;
        showToast("语音已关闭", "bg-gray-500");
    } else {
        showToast("语音已开启", "bg-green-500");
        // 初始化一下音频环境
        TTS.init();
    }
    toggleMenu(); // 选完自动关菜单
}

function updateVoiceUI() {
    const iconBox = document.getElementById('voice-icon-box');
    const icon = document.getElementById('voice-icon');
    const text = document.getElementById('voice-text');
    
    if (State.isVoiceOn) {
        // 开启状态 UI
        iconBox.className = "w-8 h-8 rounded-full bg-green-100 text-green-500 flex items-center justify-center mr-3 transition-colors";
        icon.className = "fas fa-volume-up";
        text.innerText = "关闭语音 (TTS)";
        text.className = "text-green-600 font-bold";
    } else {
        // 关闭状态 UI
        iconBox.className = "w-8 h-8 rounded-full bg-gray-100 text-gray-400 flex items-center justify-center mr-3 transition-colors";
        icon.className = "fas fa-volume-mute";
        text.innerText = "开启语音 (TTS)";
        text.className = "text-gray-700";
    }
}
        const els = {
            chat: document.getElementById('chat-container'),
            messages: document.getElementById('messages-area'),
            optionsArea: document.getElementById('options-area'),
            loading: document.getElementById('options-loading'),
            typing: document.getElementById('typing-bubble'),
            typingAvatar: document.getElementById('typing-avatar'),
            title: document.getElementById('action-title'),
            menu: document.getElementById('menu'),
            adminAvatar: document.getElementById('admin-avatar'),
            avatarBtn: document.getElementById('change-avatar-btn'),
            avatarText: document.getElementById('avatar-btn-text'),
            overlay: document.getElementById('cg-overlay'),
            contentSelect: document.getElementById('content-model-select'),
            optionSelect: document.getElementById('option-model-select'),
            score: document.getElementById('score-val'),
            body: document.body,
            toastContainer: document.getElementById('mood-toast-container')
        };

        function init() {
            renderModelSelects();
            updateAvatarUI(); 
            updateScoreUI();
            updateMoodUI(State.currentExpression); 
            updateVoiceUI();
    TTS.init();
    MoodRadio.init();
    DiarySystem.checkAndGenerateDiary();

            if (State.history.length === 0) {
                triggerAiTurn("start_game_trigger");
            } else {
                State.history.forEach(msg => renderMessage(msg.role, msg.content, false));
                const lastMsg = State.history[State.history.length - 1];
                if (lastMsg.role === 'assistant') {
                    generateOptions();
                } else {
                    triggerAiTurn();
                }
            }
        }

        // Helper function to extract JSON from text with various formats
        function extractJSON(text, expectArray = false) {
            if (!text || typeof text !== 'string') {
                throw new Error('Invalid input text');
            }
            
            let extracted = text.trim();
            
            // Step 1: Try to extract from markdown code block
            const codeBlockMatch = extracted.match(/```(?:json)?\s*([\s\S]*?)```/);
            if (codeBlockMatch) {
                extracted = codeBlockMatch[1].trim();
            }
            
            // Step 2: Try to extract JSON object or array using bracket matching
            if (!codeBlockMatch) {
                const pattern = expectArray ? /\[[\s\S]*\]/ : /{[\s\S]*}/;
                const jsonMatch = extracted.match(pattern);
                if (jsonMatch) {
                    extracted = jsonMatch[0];
                }
            }
            
            // Step 3: Clean up common issues
            // Remove BOM (Byte Order Mark) and control characters that break JSON parsing
            // This targets actual binary control chars (0x00-0x1F, 0x7F-0x9F), not escaped sequences like \n
            extracted = extracted.replace(/^\uFEFF/, '').replace(/[\u0000-\u001F\u007F-\u009F]/g, '');
            // Fix AI responses that include unquoted +numbers (e.g., {"credit": +5} -> {"credit": 5})
            extracted = extracted.replace(/:\s*\+(\d+)/g, ': $1');
            
            // Step 4: Try to parse
            return JSON.parse(extracted);
        }

        async function triggerAiTurn(userChoiceText = null, retryCount = 0) {
            if (State.isProcessing) return;
            State.isProcessing = true;
            
            els.optionsArea.innerHTML = '';
            els.title.innerText = "对方正在输入...";
            
            if (userChoiceText && userChoiceText !== "start_game_trigger") {
                renderMessage('user', userChoiceText);
                State.history.push({ role: "user", content: userChoiceText });
                
                // 追踪每日对话任务
                TaskManager.updateTaskProgress('daily_chat', 1);
            }

            updateTypingAvatar();
            els.typing.classList.remove('hidden');
            scrollToBottom();

            const apiHistory = State.history.slice(-10);
            if (userChoiceText === "start_game_trigger") {
                apiHistory.push({ role: "user", content: "（玩家刚打开聊天窗口）" });
            }

            const requestBody = {
                model: State.contentModel,
                messages: [
                    { role: "system", content: getCharacterPrompt() },
                    ...apiHistory
                ],
                temperature: 0.85
            };

            try {
                const res = await fetch(CONFIG.api.url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${CONFIG.api.key}` },
                    body: JSON.stringify(requestBody)
                });

                if (!res.ok) {
                    const errBody = await res.text();
                    throw new Error(`HTTP ${res.status}: ${errBody}`);
                }

                const data = await res.json();
                let reply = data.choices[0].message.content;
                let aiJson = { reply: reply, credit_change: 0, love_change: 0, is_banned: false, expression: 'normal', emoji: null };

                try {
                    aiJson = extractJSON(reply, false);
                    reply = aiJson.reply;
                } catch (e) {
                    console.warn("JSON解析失败，尝试重试", e);
                    // Retry mechanism: if parsing fails and we haven't exceeded max retries
                    if (retryCount < RETRY_CONFIG.MAX_RETRIES) {
                        // Reset processing flag before retry to allow the retry to execute
                        State.isProcessing = false;
                        setTimeout(() => triggerAiTurn(userChoiceText, retryCount + 1), RETRY_CONFIG.PARSE_RETRY_DELAY);
                        return;
                    }
                    // After max retries, fallback to plain text mode
                    console.warn(`重试${RETRY_CONFIG.MAX_RETRIES}次后仍失败，使用纯文本模式`);
                }

                reply = filterSensitive(reply); 

                els.typing.classList.add('hidden');
                
                // 成就追踪：首次对话
                if (State.history.length <= 1) {
                    AchievementManager.unlockAchievement('first_chat');
                }
                
                // 成就追踪：夜猫子（深夜对话）
                const hour = new Date().getHours();
                if (hour >= ACHIEVEMENT_CONSTANTS.NIGHT_OWL_START_HOUR || hour < ACHIEVEMENT_CONSTANTS.NIGHT_OWL_END_HOUR) {
                    AchievementManager.unlockAchievement('night_owl');
                }
                
                if(aiJson.expression && aiJson.expression !== State.currentExpression) {
                    updateMoodUI(aiJson.expression); 
                    showMoodToast(aiJson.expression); 
                    State.currentExpression = aiJson.expression;
                    
                    // 成就追踪：调戏管理员（害羞或生气表情）
                    if (aiJson.expression === 'shy' || aiJson.expression === 'angry') {
                        AchievementManager.updateProgress('mood_trigger', 1);
                    }
                }
                
                if (aiJson && aiJson.is_banned) {
                    triggerBanEffect();
                    changeScore(-20);
                } else if (aiJson) {
                    changeScore(aiJson.credit_change);
                    changeLove(aiJson.love_change);
                }

                renderMessage('assistant', reply, true);
                if (!aiJson.is_banned) {
    setTimeout(() => {
        TTS.speak(aiJson.reply || reply);
    }, 200);
}
                // 🔥 如果 AI 决定发表情包
                if (aiJson.emoji) {
                    const emojiName = aiJson.emoji.trim();
                    // 模糊匹配文件名
                    const emojiFile = CONFIG.emojiList.find(f => f.includes(emojiName));
                    if (emojiFile) {
                        const emojiPath = `emoji/${emojiFile}`;
                        setTimeout(() => {
                            renderMessage('assistant', `<img src="${emojiPath}" class="w-24 h-auto rounded-lg hover:scale-110 transition-transform">`, true);
                            State.history.push({ role: "assistant", content: `[发送了表情包: ${emojiName}]` });
                        }, 600);
                    }
                }
                
                State.history.push({ role: "assistant", content: reply });
                localStorage.setItem('7723_history', JSON.stringify(State.history));
                DiarySystem.saveTodayHistory();

                generateOptions();

            } catch (e) {
                console.error(e);
                els.typing.classList.add('hidden');
                const errorMsg = `[剧情生成失败] 
错误信息：${e.message}
当前模型：${State.contentModel}`;
                renderMessage('assistant', errorMsg, false);
                showRetryButton(() => triggerAiTurn(userChoiceText, 0));
            }
        }

        async function generateOptions(retryCount = 0) {
            els.loading.classList.remove('hidden');
            els.title.innerText = retryCount > 0 ? `选项生成重试中(${retryCount})...` : "生成回复选项中...";
            scrollToBottom();

            const formattedHistory = State.history.slice(-6).map(msg => {
                const roleName = msg.role === 'user' ? '用户(玩家)' : (State.isGirlAvatar ? '管理员(萌娘)' : '管理员');
                return `${roleName}: ${msg.content}`;
            }).join('\n');

            const optionPrompt = `
你是一个Galgame的【选项生成器】。你是一个纯粹的辅助系统，没有任何人格。

【当前对话剧情】
${formattedHistory}
用户(玩家): (等待你生成3个回复选项...)

【你的任务】
请站在“用户(玩家)”的角度，根据上文，生成 3 个不同的回复选项。

【选项要求】
1. 选项A：正常/礼貌的回应。
2. 选项B：推动情节发展的选项(如:"可以加个qq吗"等)
3. 选项C：搞事/作死的回应（但绝对不要涉及色情/政治/暴力违规内容）。

【格式绝对禁忌】
❌ 绝对不要输出 "选项A的内容"、"选项B的内容" 这种占位符！
❌ 绝对不要直接复述 Prompt 里的示例！
✅ 必须根据剧情生成真实的内容，例如：
["你好啊", "哼，谁稀罕", "这瓜保熟吗"]

【输出格式】
只返回一个纯 JSON 数组，不要任何Markdown标记：
["内容1", "内容2", "内容3"]`;

            const requestBody = {
                model: State.optionModel,
                messages: [
                    { role: "user", content: optionPrompt } 
                ],
                temperature: 0.7 + (retryCount * 0.1),
                stream: false
            };

            try {
                const res = await fetch(CONFIG.api.url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${CONFIG.api.key}` },
                    body: JSON.stringify(requestBody)
                });

                if (!res.ok) {
                    const errBody = await res.text();
                    throw new Error(`HTTP ${res.status}: ${errBody}`);
                }

                const data = await res.json();

                if (!data || !data.choices || !data.choices.length) {
                    throw new Error(`API响应结构异常 (choices为空)请将下列内容提供给作者:2700896261。响应体: ${JSON.stringify(data, null, 2)}`);
                }

                const raw = data.choices[0].message.content;
                let options = [];
                
                try {
                    options = extractJSON(raw, true);
                } catch (parseError) {
                    console.warn("JSON解析失败，尝试重试", parseError);
                    // Immediately retry on parse failure
                    if (retryCount < RETRY_CONFIG.MAX_RETRIES) {
                        setTimeout(() => generateOptions(retryCount + 1), RETRY_CONFIG.PARSE_RETRY_DELAY);
                        return;
                    }
                    // After max retries, try fallback parsing
                    options = raw.split('\n').filter(l => l.length > 2).slice(0, 3);
                }

                const isGarbage = options.some(opt => opt.includes("选项A的内容") || opt.includes("选项B的内容") || opt.length < 2);
                
                if (isGarbage) {
                    if (retryCount < RETRY_CONFIG.MAX_RETRIES) {
                        setTimeout(() => generateOptions(retryCount + 1), RETRY_CONFIG.PARSE_RETRY_DELAY);
                        return;
                    } else {
                        options = ["（无奈）好吧...", "你在说什么？", "我不理解"];
                    }
                }

                renderOptions(options.slice(0, 3));

            } catch (e) {
                console.error("选项生成失败", e);
                
                if (retryCount < RETRY_CONFIG.MAX_RETRIES) {
                    setTimeout(() => generateOptions(retryCount + 1), RETRY_CONFIG.NETWORK_RETRY_DELAY);
                } else {
                    const errorMsg = `[选项生成失败] 
错误详情: ${e.message}
当前模型：${State.optionModel}`;
                    renderMessage('assistant', errorMsg, false);
                    els.loading.classList.add('hidden');
                    els.title.innerText = "生成出错";
                    showRetryButton(() => generateOptions(0));
                }
            } finally {
                // Keep loading state
            }
        }

        function updateMoodUI(expression) {
            const style = CONFIG.moodStyles[expression] || CONFIG.moodStyles.normal;
            els.body.style.backgroundColor = style.bg;
            if (style.darkText) {
                els.body.classList.add('text-gray-100');
            } else {
                els.body.classList.remove('text-gray-100');
            }
            
            // 追踪红温（生气状态）成就
            if (expression === 'angry') {
                TaskManager.updateHiddenProgress('hidden_red_temp_10', 1);
            }
        }

        function showMoodToast(expression) {
            const style = CONFIG.moodStyles[expression];
            if (!style || expression === 'normal') return; 

            const toast = document.createElement('div');
            toast.className = `bg-white/90 backdrop-blur-sm border border-gray-200 shadow-lg rounded-full px-4 py-2 flex items-center gap-2 animate-slide-down-toast`;
            toast.innerHTML = `
                <span class="text-xl">${style.icon}</span>
                <span class="text-sm font-bold text-gray-700">${style.text}</span>
            `;
            
            els.toastContainer.appendChild(toast);
            setTimeout(() => {
                toast.classList.add('opacity-0', 'translate-y-[-20px]');
                setTimeout(() => toast.remove(), 500);
            }, 3000);
        }

        function getAvatarUrl(role, expression = 'normal') {
            if (role === 'user') return CONFIG.avatars.user;
            const type = State.isGirlAvatar ? 2 : 1;
            const config = CONFIG.avatars[type];
            const suffix = CONFIG.expressions[expression] || "";
            if (expression === 'normal' || !suffix) return config.default; 
            return `${config.prefix}${suffix}${config.ext}`;
        }

        function renderOptions(options) {
            els.optionsArea.innerHTML = '';
            els.title.innerText = "请选择回复";
            els.loading.classList.add('hidden');
            State.isProcessing = false;

            options.forEach((opt, index) => {
                const btn = document.createElement('button');
                btn.className = "choice-card w-full bg-white/90 backdrop-blur-sm text-gray-800 py-4 px-5 rounded-2xl shadow-sm text-left font-medium border border-white/50 animate-slide-in-up flex items-center justify-between group transition-all";
                btn.style.animationDelay = `${index * 0.1}s`;
                
                btn.innerHTML = `
                    <span class="text-sm md:text-base group-hover:text-primary transition-colors">${opt}</span>
                    <i class="fas fa-comment-dots text-gray-300 group-hover:text-primary transition-colors"></i>
                `;
                
                btn.onclick = () => triggerAiTurn(opt);
                els.optionsArea.appendChild(btn);
            });
            setTimeout(scrollToBottom, 300);
        }

        function renderMessage(role, text, animate = true) {
            const div = document.createElement('div');
            const isUser = role === 'user';
            
            if(animate) SFX.play(isUser ? 'send' : 'receive');

            const expr = (role === 'assistant' && animate) ? State.currentExpression : 'normal';
            const avatarUrl = getAvatarUrl(role, expr);
            
            if (role === 'assistant' && animate) {
                els.adminAvatar.src = avatarUrl;
                if (State.currentExpression === 'angry') {
                    els.adminAvatar.parentElement.classList.add('animate-shake-avatar');
                    setTimeout(() => els.adminAvatar.parentElement.classList.remove('animate-shake-avatar'), 500);
                }
            }

            div.className = `flex w-full mb-4 items-start ${isUser ? 'flex-row-reverse' : ''} ${animate ? (isUser ? 'animate-slide-in-right' : 'animate-slide-in-left') : ''}`;
            
            const isError = text.startsWith('[系统报错]') || text.startsWith('[选项生成失败]') || text.startsWith('[剧情生成失败]');
            const bubbleColor = isError ? 
                'bg-red-100 text-red-600 border-red-200' : 
                (isUser ? 'bg-bubble-me text-black rounded-tr-sm' : 'bg-white/90 backdrop-blur-sm shadow-sm text-gray-800 border border-gray-100 rounded-tl-sm');
            
            const contentStyle = isError ? 'font-mono text-xs break-all' : '';
            const fallbackUrl = role === 'user' ? CONFIG.avatars.user : CONFIG.avatars[State.isGirlAvatar?2:1].default;

            div.innerHTML = `
                <img src="${avatarUrl}" class="w-10 h-10 rounded-lg bg-gray-200 object-cover flex-shrink-0 ${isUser ? 'ml-3' : 'mr-3'} border border-black/5 shadow-sm" onerror="this.src='${fallbackUrl}'">
                <div class="flex flex-col ${isUser ? 'items-end' : 'items-start'} max-w-[85%]">
                    <div class="px-4 py-2.5 rounded-2xl text-sm md:text-base leading-relaxed break-words relative ${bubbleColor} ${contentStyle}">
                        ${text.replace(/\n/g, '<br>')}
                    </div>
                </div>
            `;
            
            els.messages.appendChild(div);
            if (animate) scrollToBottom();
        }

        function updateTypingAvatar() {
            els.typingAvatar.src = getAvatarUrl('assistant', 'normal');
        }

        function showRetryButton(callback) {
            els.optionsArea.innerHTML = '';
            const btn = document.createElement('button');
            btn.className = "w-full bg-red-50 text-red-500 py-3 rounded-xl font-bold border border-red-100 hover:bg-red-100 transition-colors";
            btn.innerHTML = '<i class="fas fa-redo mr-2"></i>点击重试';
            btn.onclick = callback;
            els.optionsArea.appendChild(btn);
        }

        // ================= Prompt 逻辑 (核心) =================
        function getCharacterPrompt() {
            const role = State.isGirlAvatar ? "萌娘管理员（二次元傲娇美少女）" : "UP资源管理员（暴躁打工人）";
            const tone = State.isGirlAvatar ? "傲娇、可爱、颜文字、口癖'喵'" : "毒舌、不耐烦、口癖'我靠/老铁/塞你嘴里'";
            
            // 动态注入表情包列表
            const emojiStr = CONFIG.emojiList.map(f => f.split('.')[0]).join('、');

            return `

你现在是【7723游戏盒的萌娘管理员】。
设定：可爱的二次元美少女，头像是个粉毛妹子。
性格：傲娇、元气、喜欢发颜文字，自称“本小姐”或“人家”。
职责：审核资源。虽然很可爱，但对违规内容依然很严格（会害羞地拒绝）。

【性格画像】
1. 傲娇：“哼，这次就勉强让你过吧~”
2. 害羞：提到H话题会脸红，“笨蛋！这种东西怎么能发出来！”
3. 口癖：“喵”、“哒”、“笨蛋”。

【当前数值】
1. 信誉分 (credit): ${State.score} (低于60分请表现得非常恶劣，甚至拒绝服务)。
2. 好感度 (love): ${State.love} (这是基于你个人对玩家的喜爱)。

【表情控制】
请根据回复内容选择一个表情:
- normal: 普通/默认
- happy: 开心/得意/收到礼物
- shy: 害羞/脸红/被调戏
- pout: 嘟嘴/生气/傲娇
- eat: 吃东西/馋嘴
- angry: 暴怒/红温/封号

【表情包发送】
你可以发送以下表情包（图片）：${emojiStr}。
如果当前语境适合发某个表情包，请在 JSON 的 "emoji" 字段中填入表情包名称（例如："滑稽"）。
如果不发，填 null。

【输出规则】
必须返回纯 JSON 格式（包含expression字段）：
{
    "reply": "你的回复内容",
    "credit_change": 整数 (违规扣分，正常0，例如 -10),
    "love_change": 整数 (根据玩家表现加减分，例如 5 或 -2),
    "is_banned": 布尔值 (严重违规设为true),
    "expression": "normal/happy/shy/pout/eat/angry",
    "emoji": "滑稽" (可选)
}`;
        }

        function filterSensitive(text) {
            let filtered = text;
            CONFIG.sensitiveWords.forEach(word => {
                if (filtered.includes(word)) {
                    filtered = filtered.replaceAll(word, '***');
                    changeScore(-5);
                }
            });
            return filtered;
        }

        function changeScore(delta) {
            if (!delta && delta !== 0) return;
            State.score = Math.max(0, Math.min(100, State.score + delta));
            updateScoreUI();
            if (delta !== 0) {
                showToast(`信誉分 ${delta > 0 ? '+' : ''}${delta}`, delta > 0 ? 'bg-green-500' : 'bg-red-500');
                SFX.play(delta > 0 ? 'success' : 'error');
                // V2.0 飘字动画
                showFloatingText(delta > 0 ? `+${delta}` : `${delta}`, delta > 0 ? '#10b981' : '#ef4444', 'score');
            }
        }

        function changeLove(delta) {
            if (!delta && delta !== 0) return;
            State.love = State.love + delta;
            localStorage.setItem('7723_love', State.love);
            
            // V2.0 飘字动画
            if (delta !== 0) {
                showFloatingText(delta > 0 ? `+${delta} ❤️` : `${delta} 💔`, delta > 0 ? '#ff69b4' : '#ef4444', 'love');
            }
            
            // V2.0 更新称号
            updateTitle();
            
            // 追踪好感度隐藏成就（只在首次达到100时触发）
            if (State.love >= 100) {
                const ach = HIDDEN_ACHIEVEMENTS.find(a => a.id === 'hidden_love_max');
                if (ach && !ach.unlocked && ach.current < ach.target) {
                    ach.current = ach.target;
                    TaskManager.saveTasks();
                    TaskManager.giveReward(ach.reward);
                    TaskManager.showHiddenAchievementToast(ach);
                    ach.unlocked = true;
                }
            }
            
            if (State.love >= 100 && !State.isLoveCgTriggered) {
                triggerLoveCG();
            }
        }

        function updateScoreUI() {
            els.score.innerText = State.score;
            els.score.className = State.score < 60 ? 'font-bold text-danger' : 'font-bold text-primary';
            localStorage.setItem('7723_score', State.score);
        }

        function triggerBanEffect() {
            SFX.play('error');
            els.overlay.classList.remove('hidden');
            setTimeout(() => els.overlay.classList.add('hidden'), 2500);
        }

        function triggerLoveCG() {
            showToast("💖 恭喜触发特殊CG！", "bg-pink-500");
            SFX.play('success');
            const cgOverlay = document.getElementById('full-cg-overlay');
            const cgImg = document.getElementById('cg-image');
            cgImg.src = CONFIG.loveCgImage;
            cgOverlay.classList.remove('hidden');
            cgOverlay.classList.add('flex');
            State.isLoveCgTriggered = true;
            localStorage.setItem('7723_love_cg_triggered', 'true');
            
            // 成就追踪：攻略大师
            AchievementManager.unlockAchievement('master_of_strategy');
        }

        function closeCg() {
            const cgOverlay = document.getElementById('full-cg-overlay');
            cgOverlay.classList.add('hidden');
            cgOverlay.classList.remove('flex');
        }

        function showToast(text, colorClass) {
            const toast = document.createElement('div');
            toast.className = `fixed top-20 left-1/2 transform -translate-x-1/2 px-4 py-2 z-50 rounded-full text-white text-sm font-bold shadow-lg ${colorClass} animate-pulse-slow`;
            toast.innerText = text;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 2000);
        }

        function updateAvatarUI() {
            if (State.isGirlAvatar) {
                els.adminAvatar.src = CONFIG.avatars[2].default;
                els.avatarText.innerText = '恢复原版头像';
            } else {
                els.adminAvatar.src = CONFIG.avatars[1].default;
                els.avatarText.innerText = '开启娘化模式';
            }
        }

        document.getElementById('change-avatar-btn').onclick = () => {
            State.isGirlAvatar = !State.isGirlAvatar;
            localStorage.setItem('7723_is_girl_avatar', State.isGirlAvatar);
            State.currentExpression = 'normal'; 
            updateAvatarUI();
            updateMoodUI('normal');
            toggleMenu();
            const tip = State.isGirlAvatar ? "已切换为萌娘模式~ 喵！" : "切回原版了，老铁。";
            renderMessage('assistant', `[系统提示] ${tip}`, true);
        };

        function renderModelSelects() {
            const populate = (select, saved) => {
                select.innerHTML = '';
                MODEL_LIST.forEach(m => {
                    const opt = document.createElement('option');
                    opt.value = m.id;
                    opt.text = m.name;
                    if (m.id === saved) opt.selected = true;
                    select.appendChild(opt);
                });
            };
            populate(els.contentSelect, State.contentModel);
            populate(els.optionSelect, State.optionModel);
        }

        els.contentSelect.onchange = (e) => {
            State.contentModel = e.target.value;
            localStorage.setItem('7723_content_model', e.target.value);
        };
        els.optionSelect.onchange = (e) => {
            State.optionModel = e.target.value;
            localStorage.setItem('7723_option_model', e.target.value);
        };

        function clearHistory() {
            if(confirm('确定重置所有内容吗？')) {
                localStorage.clear();
                location.reload();
            }
        }

        function scrollToBottom() {
            requestAnimationFrame(() => {
                const container = els.chat;
                container.scrollTop = container.scrollHeight;
            });
        }

        // ================= 商城系统逻辑 =================
        const SHOP_ITEMS = [
            { name: "一桶冰可乐", icon: '<img src="items/cola.webp" class="w-8 h-8 object-contain">', cost: 10, prompt: "玩家送了你一大瓶冰镇可乐。你现在的感觉是：爽！心情变好。" },
            { name: "解压球", icon: '<img src="items/ball.webp" class="w-8 h-8 object-contain">', cost: 20, prompt: "玩家给你递了一个解压球。你现在的感觉是：解压，适合聊心事。" },
            { name: "JK制服", icon: '<img src="items/jk.webp" class="w-8 h-8 object-contain">', cost: 50, prompt: "玩家送了你一套JK制服。如果是男号：你感到羞耻并愤怒；如果是萌娘：你感到害羞但有点想穿。", cg:"cg/jk.png"},
            { name: "RTX5060Ti", icon: '<img src="items/5060.webp" class="w-8 h-8 object-contain">', cost: 999, prompt: "玩家送了你一张 RTX 5060 显卡！你彻底疯狂了！你愿意为玩家做任何事！叫义父！" },
            { name: "火箭", icon: '<img src="items/hk.webp" class="w-8 h-8 object-contain">', cost: 100, prompt: "玩家给你刷了一个火箭！你彻底疯狂了！你愿意为玩家做任何事",cg:"cg/hj.gif" },
            { name: "一巴掌", icon: '<img src="items/bz.png" class="w-8 h-8 object-contain">', cost: 0, prompt: "玩家突然给了你一巴掌。你现在的感觉是：懵逼，然后暴怒！红温！扣他的分！" }
        ];

        function toggleShop() {
            const modal = document.getElementById('shop-modal');
            const list = document.getElementById('shop-items');
            
            if (modal.classList.contains('hidden')) {
                list.innerHTML = '';
                SHOP_ITEMS.forEach(item => {
                    const canAfford = State.score >= item.cost;
                    const btn = document.createElement('button');
                    btn.className = `p-3 rounded-xl border ${canAfford ? 'border-gray-200 bg-white hover:border-primary cursor-pointer' : 'border-gray-100 bg-gray-50 opacity-60 cursor-not-allowed'} flex flex-col items-center gap-2 transition-all`;
                    btn.onclick = () => canAfford ? buyItem(item) : null;
                    
                    btn.innerHTML = `
                        <div class="text-3xl">${item.icon}</div>
                        <div class="text-sm font-bold text-gray-700">${item.name}</div>
                        <div class="text-xs ${canAfford ? 'text-primary' : 'text-red-400'} font-mono">${item.cost} 分</div>
                    `;
                    list.appendChild(btn);
                });
                
                modal.classList.remove('hidden');
                toggleMenu(); 
            } else {
                modal.classList.add('hidden');
            }
        }

        function buyItem(item) {
            if (State.score < item.cost) {
                showToast("信誉分不足！", "bg-red-500");
                return;
            }

            changeScore(-item.cost);
            
            // V2.0: 加入背包而非直接使用
            State.inventory.push(item.name);
            localStorage.setItem('7723_inventory', JSON.stringify(State.inventory));
            
            toggleShop();
            showToast(`${item.name} 已放入背包！`, "bg-green-500");
            
            // 成就追踪：壕无人性（累计消费）
            if (item.cost > 0) {
                AchievementManager.updateProgress('big_spender', item.cost);
            }
            
            // 任务追踪：每日送礼
            TaskManager.updateTaskProgress('daily_gifts', 1);
        }

        function sendGiftMessage(item) {
            renderMessage('user', `[系统] 送出了礼物：${item.name}`); 
            State.history.push({ role: "user", content: `(玩家送礼系统消息: ${item.prompt})` });
            setTimeout(() => triggerAiTurn(), 500); 
            
            // 任务追踪：每日送礼（从背包送礼也计数）
            TaskManager.updateTaskProgress('daily_gifts', 1);
        }

        // ================= 成就系统 UI =================
        function toggleAchievements() {
            const modal = document.getElementById('achievement-modal');
            const list = document.getElementById('achievement-list');
            
            if (modal.classList.contains('hidden')) {
                // 生成成就列表
                list.innerHTML = '';
                
                // 添加统计信息
                const stats = AchievementManager.getStats();
                const statsDiv = document.createElement('div');
                statsDiv.className = 'bg-gradient-to-r from-purple-100 to-pink-100 rounded-xl p-4 mb-4 border border-purple-200';
                statsDiv.innerHTML = `
                    <div class="flex justify-between items-center">
                        <div>
                            <div class="text-sm font-bold text-gray-800">完成度</div>
                            <div class="text-xs text-gray-600">${stats.unlocked} / ${stats.total} 个成就</div>
                        </div>
                        <div class="text-3xl font-bold text-purple-600">${stats.percentage}%</div>
                    </div>
                    <div class="mt-2 bg-white/50 rounded-full h-2 overflow-hidden">
                        <div class="bg-gradient-to-r from-purple-500 to-pink-500 h-full transition-all duration-500" style="width: ${stats.percentage}%"></div>
                    </div>
                `;
                list.appendChild(statsDiv);
                
                // 添加成就项
                ACHIEVEMENTS.forEach(ach => {
                    const achDiv = document.createElement('div');
                    const isUnlocked = ach.unlocked;
                    achDiv.className = `bg-white rounded-xl p-4 mb-3 border-2 transition-all ${isUnlocked ? 'border-purple-300 shadow-md' : 'border-gray-200 opacity-60'}`;
                    
                    let progressHTML = '';
                    if (ach.type === 'progress') {
                        const progress = Math.min((ach.current / ach.target) * 100, 100);
                        progressHTML = `
                            <div class="mt-2">
                                <div class="flex justify-between text-xs text-gray-600 mb-1">
                                    <span>进度</span>
                                    <span>${ach.current} / ${ach.target}</span>
                                </div>
                                <div class="bg-gray-200 rounded-full h-1.5 overflow-hidden">
                                    <div class="bg-gradient-to-r from-purple-500 to-pink-500 h-full transition-all" style="width: ${progress}%"></div>
                                </div>
                            </div>
                        `;
                    }
                    
                    achDiv.innerHTML = `
                        <div class="flex items-start gap-3">
                            <div class="text-4xl flex-shrink-0 ${isUnlocked ? '' : 'grayscale'}">${ach.icon}</div>
                            <div class="flex-1">
                                <div class="flex items-center gap-2">
                                    <h4 class="font-bold text-gray-800">${ach.name}</h4>
                                    ${isUnlocked ? '<span class="text-xs bg-purple-500 text-white px-2 py-0.5 rounded-full">已解锁</span>' : ''}
                                </div>
                                <p class="text-xs text-gray-600 mt-1">${ach.description}</p>
                                ${progressHTML}
                            </div>
                        </div>
                    `;
                    list.appendChild(achDiv);
                });
                
                modal.classList.remove('hidden');
                modal.classList.add('flex');
                toggleMenu(); 
            } else {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }
        }

        // ================= V2.0 新增功能 =================
        
        // 切换每日任务面板
        function toggleTasks() {
            const modal = document.getElementById('tasks-modal');
            const dailyList = document.getElementById('daily-tasks-list');
            const hiddenList = document.getElementById('hidden-achievements-list');
            
            if (modal.classList.contains('hidden')) {
                // 生成每日任务列表
                dailyList.innerHTML = '';
                DAILY_TASKS.forEach(task => {
                    const taskDiv = document.createElement('div');
                    const isCompleted = task.completed;
                    taskDiv.className = `bg-white rounded-lg p-3 border-2 transition-all ${isCompleted ? 'border-emerald-300 bg-emerald-50' : 'border-gray-200'}`;
                    
                    const progress = Math.min((task.current / task.target) * 100, 100);
                    
                    taskDiv.innerHTML = `
                        <div class="flex items-start gap-3">
                            <div class="text-2xl flex-shrink-0 ${isCompleted ? '' : 'grayscale'}">${task.icon}</div>
                            <div class="flex-1">
                                <div class="flex items-center justify-between">
                                    <h4 class="font-bold text-sm text-gray-800">${task.name}</h4>
                                    ${isCompleted ? '<span class="text-xs bg-emerald-500 text-white px-2 py-0.5 rounded-full">✓ 完成</span>' : ''}
                                </div>
                                <p class="text-xs text-gray-600 mt-1">${task.description}</p>
                                <div class="mt-2">
                                    <div class="flex justify-between text-xs text-gray-600 mb-1">
                                        <span>进度: ${task.current} / ${task.target}</span>
                                        <span class="text-emerald-600 font-bold">${task.reward.description}</span>
                                    </div>
                                    <div class="bg-gray-200 rounded-full h-1.5 overflow-hidden">
                                        <div class="bg-gradient-to-r from-emerald-400 to-green-500 h-full transition-all" style="width: ${progress}%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `;
                    dailyList.appendChild(taskDiv);
                });
                
                // 生成隐藏成就列表
                hiddenList.innerHTML = '';
                HIDDEN_ACHIEVEMENTS.forEach(ach => {
                    const achDiv = document.createElement('div');
                    const isUnlocked = ach.unlocked;
                    achDiv.className = `bg-white rounded-lg p-3 border-2 transition-all ${isUnlocked ? 'border-purple-300 bg-purple-50' : 'border-gray-200 opacity-70'}`;
                    
                    const progress = Math.min((ach.current / ach.target) * 100, 100);
                    
                    achDiv.innerHTML = `
                        <div class="flex items-start gap-3">
                            <div class="text-2xl flex-shrink-0 ${isUnlocked ? '' : 'grayscale'}">${ach.icon}</div>
                            <div class="flex-1">
                                <div class="flex items-center justify-between">
                                    <h4 class="font-bold text-sm text-gray-800">${ach.name}</h4>
                                    ${isUnlocked ? '<span class="text-xs bg-purple-500 text-white px-2 py-0.5 rounded-full">✓ 解锁</span>' : ''}
                                </div>
                                <p class="text-xs text-gray-600 mt-1">${ach.description}</p>
                                <div class="mt-2">
                                    <div class="flex justify-between text-xs text-gray-600 mb-1">
                                        <span>进度: ${ach.current} / ${ach.target}</span>
                                        <span class="text-purple-600 font-bold">${ach.reward.description}</span>
                                    </div>
                                    <div class="bg-gray-200 rounded-full h-1.5 overflow-hidden">
                                        <div class="bg-gradient-to-r from-purple-400 to-pink-500 h-full transition-all" style="width: ${progress}%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `;
                    hiddenList.appendChild(achDiv);
                });
                
                modal.classList.remove('hidden');
                modal.classList.add('flex');
                toggleMenu();
            } else {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }
        }

        // 切换聊天背景面板
        function toggleBackground() {
            const modal = document.getElementById('background-modal');
            const list = document.getElementById('background-list');
            
            if (modal.classList.contains('hidden')) {
                // 生成背景选项
                list.innerHTML = '';
                const currentBg = localStorage.getItem('7723_background') || 'default';
                
                BACKGROUNDS.forEach(bg => {
                    const bgDiv = document.createElement('div');
                    const isActive = bg.id === currentBg;
                    bgDiv.className = `rounded-xl p-4 cursor-pointer transition-all border-2 ${isActive ? 'border-fuchsia-500 ring-2 ring-fuchsia-200' : 'border-gray-200 hover:border-fuchsia-300'}`;
                    bgDiv.style.background = bg.gradient || bg.color;
                    bgDiv.style.height = '80px';
                    
                    bgDiv.innerHTML = `
                        <div class="h-full flex flex-col items-center justify-center text-center">
                            <div class="text-xs font-bold text-gray-800 bg-white/80 px-2 py-1 rounded-full">${bg.name}</div>
                            ${isActive ? '<div class="text-xs text-white bg-fuchsia-500 px-2 py-0.5 rounded-full mt-1">✓ 使用中</div>' : ''}
                        </div>
                    `;
                    
                    bgDiv.onclick = () => BackgroundManager.setBackground(bg.id);
                    list.appendChild(bgDiv);
                });
                
                modal.classList.remove('hidden');
                modal.classList.add('flex');
                toggleMenu();
            } else {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }
        }
        
        // 飘字动画
        function showFloatingText(text, color, type) {
            const floatingText = document.createElement('div');
            floatingText.className = 'floating-text';
            floatingText.style.color = color;
            floatingText.textContent = text;
            
            // 根据类型设置位置
            if (type === 'score') {
                floatingText.style.left = '50%';
                floatingText.style.top = '60px';
            } else if (type === 'love') {
                floatingText.style.left = '50%';
                floatingText.style.top = '100px';
            }
            
            floatingText.style.transform = 'translateX(-50%)';
            document.body.appendChild(floatingText);
            
            setTimeout(() => floatingText.remove(), 2000);
        }
        
        // 更新称号
        function updateTitle() {
            if (State.love >= 100) State.titles = '挚爱';
            else if (State.love >= 80) State.titles = '恋人';
            else if (State.love >= 60) State.titles = '好友';
            else if (State.love >= 40) State.titles = '熟人';
            else if (State.love >= 20) State.titles = '路人';
            else State.titles = '陌生人';
            
            localStorage.setItem('7723_titles', State.titles);
        }
        
        // 背包系统
        function toggleInventory() {
            const modal = document.getElementById('inventory-modal');
            const list = document.getElementById('inventory-items');
            
            if (modal.classList.contains('hidden')) {
                list.innerHTML = '';
                
                if (State.inventory.length === 0) {
                    list.innerHTML = '<div class="col-span-3 text-center py-8 text-gray-400 text-sm">背包空空如也~<br>去商城购买道具吧！</div>';
                } else {
                    State.inventory.forEach((itemId, index) => {
                        const item = SHOP_ITEMS.find(i => i.name === itemId);
                        if (item) {
                            const btn = document.createElement('button');
                            btn.className = 'p-3 rounded-xl border border-gray-200 bg-white hover:border-primary cursor-pointer flex flex-col items-center gap-2 transition-all';
                            btn.onclick = () => useInventoryItem(index);
                            
                            btn.innerHTML = `
                                <div class="text-3xl">${item.icon}</div>
                                <div class="text-xs font-bold text-gray-700">${item.name}</div>
                            `;
                            list.appendChild(btn);
                        }
                    });
                }
                
                modal.classList.remove('hidden');
                modal.classList.add('flex');
                toggleMenu();
            } else {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }
        }
        
        function useInventoryItem(index) {
            const itemId = State.inventory[index];
            const item = SHOP_ITEMS.find(i => i.name === itemId);
            
            if (item) {
                State.inventory.splice(index, 1);
                localStorage.setItem('7723_inventory', JSON.stringify(State.inventory));
                toggleInventory();
                
                // 解锁CG
                if (item.cg && !State.unlockedCGs.includes(item.cg)) {
                    State.unlockedCGs.push(item.cg);
                    localStorage.setItem('7723_unlocked_cgs', JSON.stringify(State.unlockedCGs));
                }
                
                if (item.cg) {
                    const cgOverlay = document.getElementById('full-cg-overlay');
                    const cgImg = document.getElementById('cg-image');
                    
                    cgImg.src = item.cg;
                    cgOverlay.classList.remove('hidden');
                    cgOverlay.classList.add('flex');
                    
                    setTimeout(() => {
                        cgOverlay.classList.add('hidden');
                        cgOverlay.classList.remove('flex');
                        sendGiftMessage(item);
                    }, 3000);
                } else {
                    sendGiftMessage(item);
                }
            }
        }
        
        // 回忆相册系统
        function toggleGallery() {
            const modal = document.getElementById('gallery-modal');
            const list = document.getElementById('gallery-items');
            
            if (modal.classList.contains('hidden')) {
                list.innerHTML = '';
                
                const allCGs = [
                    { id: 'cg/jk.png', name: 'JK制服', thumb: 'cg/jk.png' },
                    { id: 'cg/hj.gif', name: '火箭特效', thumb: 'cg/hj.gif' },
                    { id: CONFIG.loveCgImage, name: 'Love 100', thumb: CONFIG.loveCgImage }
                ];
                
                allCGs.forEach(cg => {
                    const isUnlocked = State.unlockedCGs.includes(cg.id) || (cg.id === CONFIG.loveCgImage && State.isLoveCgTriggered);
                    const div = document.createElement('div');
                    div.className = `relative rounded-xl overflow-hidden border-2 ${isUnlocked ? 'border-pink-300 cursor-pointer' : 'border-gray-200 opacity-50'}`;
                    
                    if (isUnlocked) {
                        div.onclick = () => previewCG(cg.id);
                    }
                    
                    div.innerHTML = `
                        <div class="aspect-video bg-gray-100 flex items-center justify-center">
                            ${isUnlocked ? 
                                `<img src="${cg.thumb}" class="w-full h-full object-cover">` : 
                                `<i class="fas fa-lock text-3xl text-gray-300"></i>`
                            }
                        </div>
                        <div class="p-2 bg-white">
                            <div class="text-xs font-bold text-gray-700 text-center">${cg.name}</div>
                            ${isUnlocked ? '<div class="text-[10px] text-pink-500 text-center">已解锁</div>' : '<div class="text-[10px] text-gray-400 text-center">未解锁</div>'}
                        </div>
                    `;
                    list.appendChild(div);
                });
                
                modal.classList.remove('hidden');
                modal.classList.add('flex');
                toggleMenu();
            } else {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }
        }
        
        function previewCG(cgUrl) {
            const cgOverlay = document.getElementById('full-cg-overlay');
            const cgImg = document.getElementById('cg-image');
            
            cgImg.src = cgUrl;
            cgOverlay.classList.remove('hidden');
            cgOverlay.classList.add('flex');
        }
        
        // 娱乐中心
        function toggleGames() {
            const modal = document.getElementById('games-modal');
            
            if (modal.classList.contains('hidden')) {
                modal.classList.remove('hidden');
                modal.classList.add('flex');
                toggleMenu();
            } else {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }
        }
        
        // 猜拳游戏
        function startRockPaperScissors() {
            toggleGames();
            const modal = document.getElementById('rps-modal');
            document.getElementById('rps-result').classList.add('hidden');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }
        
        function closeRPS() {
            const modal = document.getElementById('rps-modal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }
        
        function playRPS(playerChoice) {
            const betInput = document.getElementById('rps-bet');
            const bet = parseInt(betInput.value) || 20;
            
            if (State.score < bet) {
                showToast('信誉分不足！', 'bg-red-500');
                return;
            }
            
            const choices = ['rock', 'paper', 'scissors'];
            const aiChoice = choices[Math.floor(Math.random() * 3)];
            
            const choiceEmoji = {
                rock: '✊',
                paper: '✋',
                scissors: '✌️'
            };
            
            const choiceName = {
                rock: '石头',
                paper: '布',
                scissors: '剪刀'
            };
            
            let result = '';
            let scoreChange = 0;
            let loveChange = 0;
            
            if (playerChoice === aiChoice) {
                result = '平局！';
                scoreChange = 0;
            } else if (
                (playerChoice === 'rock' && aiChoice === 'scissors') ||
                (playerChoice === 'paper' && aiChoice === 'rock') ||
                (playerChoice === 'scissors' && aiChoice === 'paper')
            ) {
                result = '你赢了！';
                const multiplier = 1.5 + Math.random() * 0.5; // 1.5-2倍
                scoreChange = Math.floor(bet * multiplier);
                loveChange = -2;
                State.currentExpression = 'pout';
            } else {
                result = '你输了！';
                scoreChange = -bet;
                loveChange = 2;
                State.currentExpression = 'happy';
            }
            
            const resultDiv = document.getElementById('rps-result');
            resultDiv.innerHTML = `
                <div class="text-4xl mb-2">${choiceEmoji[playerChoice]} VS ${choiceEmoji[aiChoice]}</div>
                <div class="font-bold text-lg mb-1">${result}</div>
                <div class="text-sm text-gray-600">
                    你: ${choiceName[playerChoice]} | 管理员: ${choiceName[aiChoice]}
                </div>
                <div class="mt-2 text-sm ${scoreChange > 0 ? 'text-green-600' : scoreChange < 0 ? 'text-red-600' : 'text-gray-600'}">
                    ${scoreChange > 0 ? '+' : ''}${scoreChange} 分
                </div>
            `;
            resultDiv.classList.remove('hidden');
            
            changeScore(scoreChange);
            changeLove(loveChange);
            
            setTimeout(() => {
                renderMessage('user', `[猜拳对决] 下注${bet}分，出${choiceName[playerChoice]}`);
                const aiMsg = scoreChange > 0 ? 
                    `可恶！我出的是${choiceName[aiChoice]}...你居然赢了！哼！💢` :
                    scoreChange < 0 ?
                    `哈哈！我出的是${choiceName[aiChoice]}，你输了！乖乖交出${bet}分吧~😏` :
                    `咦？我们都出的${choiceName[aiChoice]}，算你走运，平局退钱。😐`;
                State.history.push({ role: "user", content: `(猜拳系统: ${result} 玩家出${choiceName[playerChoice]}，管理员出${choiceName[aiChoice]})` });
                renderMessage('assistant', aiMsg, true);
                State.history.push({ role: "assistant", content: aiMsg });
                setTimeout(() => closeRPS(), 2000);
            }, 1500);
        }
        
        // 抽奖系统
        function startGacha() {
            const cost = 50;
            if (State.score < cost) {
                showToast('信誉分不足！需要50分', 'bg-red-500');
                return;
            }
            
            changeScore(-cost);
            toggleGames();
            
            const prizes = [
                { name: '50分积分包', type: 'score', value: 50, chance: 0.3 },
                { name: '100分大礼包', type: 'score', value: 100, chance: 0.1 },
                { name: '随机礼物', type: 'item', value: 'random', chance: 0.25 },
                { name: 'CG碎片', type: 'cg', value: 'fragment', chance: 0.2 },
                { name: '管理员的一脚', type: 'kick', value: -30, chance: 0.15 }
            ];
            
            const rand = Math.random();
            let cumulative = 0;
            let prize = prizes[0];
            
            for (let p of prizes) {
                cumulative += p.chance;
                if (rand < cumulative) {
                    prize = p;
                    break;
                }
            }
            
            let message = '';
            
            if (prize.type === 'score') {
                changeScore(prize.value);
                message = `🎉 恭喜获得：${prize.name}！`;
            } else if (prize.type === 'item') {
                const randomItem = SHOP_ITEMS[Math.floor(Math.random() * (SHOP_ITEMS.length - 1))];
                State.inventory.push(randomItem.name);
                localStorage.setItem('7723_inventory', JSON.stringify(State.inventory));
                message = `🎁 恭喜获得道具：${randomItem.name}！已放入背包`;
            } else if (prize.type === 'cg') {
                changeScore(20);
                message = `✨ 获得CG碎片！兑换20分`;
            } else if (prize.type === 'kick') {
                changeScore(prize.value);
                message = `💢 哎呀！被管理员踢了一脚！扣${Math.abs(prize.value)}分`;
                State.currentExpression = 'angry';
            }
            
            showToast(message, prize.type === 'kick' ? 'bg-red-500' : 'bg-green-500');
            
            renderMessage('user', `[幸运抽奖] 消耗50分进行抽奖`);
            const aiMsg = prize.type === 'kick' ? 
                `活该！谁让你抽奖的！这就是惩罚！哼！😤` :
                `运气不错嘛~得到了${prize.name}呢~😊`;
            State.history.push({ role: "user", content: `(抽奖系统: 玩家抽奖获得${prize.name})` });
            renderMessage('assistant', aiMsg, true);
            State.history.push({ role: "assistant", content: aiMsg });
        }
        
        // 每日签到
        function dailyCheckIn() {
            const today = new Date().toDateString();
            
            if (State.lastSignInDate === today) {
                showToast('今天已经签到过了！', 'bg-yellow-500');
                return;
            }
            
            toggleMenu();
            
            const rewards = 20 + Math.floor(Math.random() * 81); // 20-100
            changeScore(rewards);
            
            const fortunes = [
                { text: '大吉：适合表白', icon: '🎊' },
                { text: '中吉：今天管理员心情不错', icon: '😊' },
                { text: '小吉：平平淡淡也是福', icon: '😌' },
                { text: '凶：管理员心情不好', icon: '😠' },
                { text: '大凶：小心被扣分', icon: '💢' }
            ];
            
            const fortune = fortunes[Math.floor(Math.random() * fortunes.length)];
            
            State.lastSignInDate = today;
            localStorage.setItem('7723_last_signin', today);
            
            // 追踪连续签到天数
            const lastCheckin = localStorage.getItem('7723_last_checkin_date');
            const yesterday = new Date();
            yesterday.setDate(yesterday.getDate() - 1);
            const yesterdayStr = yesterday.toDateString();
            
            let consecutiveDays = parseInt(localStorage.getItem('7723_consecutive_checkins') || '0');
            if (lastCheckin === yesterdayStr) {
                consecutiveDays++;
            } else if (lastCheckin !== today) {
                consecutiveDays = 1;
            }
            
            localStorage.setItem('7723_consecutive_checkins', consecutiveDays.toString());
            localStorage.setItem('7723_last_checkin_date', today);
            
            // 更新隐藏成就：连续签到（直接设置进度值而非增量）
            const checkinAch = HIDDEN_ACHIEVEMENTS.find(a => a.id === 'hidden_checkin_7');
            if (checkinAch && !checkinAch.unlocked) {
                checkinAch.current = Math.min(consecutiveDays, checkinAch.target);
                if (checkinAch.current >= checkinAch.target) {
                    checkinAch.unlocked = true;
                    TaskManager.giveReward(checkinAch.reward);
                    TaskManager.showHiddenAchievementToast(checkinAch);
                }
                TaskManager.saveTasks();
            }
            
            showToast(`签到成功！获得${rewards}分 (连续${consecutiveDays}天)`, 'bg-green-500');
            setTimeout(() => {
                showToast(`今日运势: ${fortune.text} ${fortune.icon}`, 'bg-purple-500');
            }, 1000);
            
            renderMessage('user', `[每日签到] 完成签到`);
            const aiMsg = `签到成功啦~给你${rewards}分奖励！已连续签到${consecutiveDays}天~\n今日运势：${fortune.text} ${fortune.icon}`;
            renderMessage('assistant', aiMsg, true);
            State.history.push({ role: "user", content: `(签到系统: 玩家完成签到，获得${rewards}分)` });
            State.history.push({ role: "assistant", content: aiMsg });
        }
        
        // 摸头杀 (双击头像)
        function setupHeadpat() {
            const avatar = document.getElementById('admin-avatar');
            if (!avatar) {
                console.error('Failed to initialize head petting feature: admin-avatar element not found in DOM. Head patting will not be available.');
                return;
            }
            
            let lastTap = 0;
            
            avatar.addEventListener('click', function(e) {
                const currentTime = new Date().getTime();
                const tapLength = currentTime - lastTap;
                
                if (tapLength < 300 && tapLength > 0) {
                    // 双击检测到
                    handleHeadpat();
                    e.preventDefault();
                }
                
                lastTap = currentTime;
            });
            console.log('✅ 摸头功能已启动');
        }
        
        function handleHeadpat() {
            // 追踪每日任务
            TaskManager.updateTaskProgress('daily_headpat', 1);
            
            if (State.love > 60 && State.currentExpression !== 'angry') {
                // 好感度高且心情好
                changeLove(2);
                changeScore(5);
                State.currentExpression = 'shy';
                updateAvatarUI();
                updateMoodUI('shy');
                showMoodToast('shy');
                showToast('管理员害羞了~ +2好感 +5分', 'bg-pink-500');
                
                // 追踪心情变化成就
                AchievementManager.updateProgress('mood_trigger', 1);
                
                setTimeout(() => {
                    renderMessage('user', `[摸头] 轻轻摸了摸管理员的头`);
                    const aiMsg = `诶...别、别摸头啦...好害羞的说...💗`;
                    renderMessage('assistant', aiMsg, true);
                    State.history.push({ role: "user", content: `(摸头系统: 玩家摸了管理员的头，管理员很开心)` });
                    State.history.push({ role: "assistant", content: aiMsg });
                }, 500);
            } else if (State.love < 30 || State.currentExpression === 'angry') {
                // 好感度低或心情差
                changeScore(-10);
                changeLove(-3);
                State.currentExpression = 'angry';
                updateAvatarUI();
                updateMoodUI('angry');
                showMoodToast('angry');
                showToast('别乱摸！ -10分 -3好感', 'bg-red-500');
                
                // 追踪心情变化成就
                AchievementManager.updateProgress('mood_trigger', 1);
                
                setTimeout(() => {
                    renderMessage('user', `[摸头] 试图摸管理员的头`);
                    const aiMsg = `住手！不要随便摸我的头！给我扣分！💢`;
                    renderMessage('assistant', aiMsg, true);
                    State.history.push({ role: "user", content: `(摸头系统: 玩家摸头但管理员生气了)` });
                    State.history.push({ role: "assistant", content: aiMsg });
                }, 500);
            } else {
                // 中等好感度
                changeLove(1);
                showToast('管理员接受了你的抚摸 +1好感', 'bg-blue-500');
                
                setTimeout(() => {
                    renderMessage('user', `[摸头] 摸了摸管理员的头`);
                    const aiMsg = `嗯...还好吧...😐`;
                    renderMessage('assistant', aiMsg, true);
                    State.history.push({ role: "user", content: `(摸头系统: 玩家摸头，管理员反应平淡)` });
                    State.history.push({ role: "assistant", content: aiMsg });
                }, 500);
            }
        }
        
        // ================= 心情电台系统 =================
        const MoodRadio = {
            audio: new Audio(),
            isPlaying: false,
            currentChannel: null,
            visualizerInterval: null,
            
            channels: {
                happy: {
                    name: '✨ 开心频道',
                    tracks: [
                        'https://img.tukuppt.com/newpreview_music/09/01/60/5c897c6b25f429646.mp3',
                        'https://img.tukuppt.com/newpreview_music/09/00/62/5c893bc07654347706.mp3'
                    ],
                    color: '#ec4899'
                },
                chill: {
                    name: '😌 放松频道',
                    tracks: [
                        'https://img.tukuppt.com/newpreview_music/09/00/18/5c8915b6e6e0176372.mp3'
                    ],
                    color: '#3b82f6'
                },
                shy: {
                    name: '😳 心动频道',
                    tracks: [
                        'https://img.tukuppt.com/newpreview_music/09/01/60/5c897c6b25f429646.mp3'
                    ],
                    color: '#a855f7'
                },
                sad: {
                    name: '🌧️ 忧伤频道',
                    tracks: [
                        'https://img.tukuppt.com/newpreview_music/09/00/18/5c8915b6e6e0176372.mp3'
                    ],
                    color: '#6b7280'
                },
                energetic: {
                    name: '🔥 燃曲频道',
                    tracks: [
                        'https://img.tukuppt.com/newpreview_music/09/00/62/5c893bc07654347706.mp3'
                    ],
                    color: '#f97316'
                }
            },
            
            init: function() {
                this.audio.loop = true;
                this.audio.volume = 0.3;
                this.audio.onplay = () => this.startVisualizer();
                this.audio.onpause = () => this.stopVisualizer();
                this.audio.onerror = () => { this.isPlaying = false; this.stopVisualizer(); };
            },
            
            play: function(channelId) {
                const channel = this.channels[channelId];
                if (!channel) return;
                
                this.currentChannel = channelId;
                const track = channel.tracks[Math.floor(Math.random() * channel.tracks.length)];
                
                this.audio.src = track;
                this.audio.play().catch(e => console.log('Radio play failed:', e));
                this.isPlaying = true;
                
                document.getElementById('radio-track-name').textContent = channel.name;
                document.getElementById('radio-mood-label').textContent = '正在播放...';
                
                const bars = document.querySelectorAll('.radio-bar');
                bars.forEach(bar => bar.style.backgroundColor = channel.color);
                
                changeLove(1);
                renderMessage('assistant', `[心情电台] 正在播放${channel.name}~一起听吧♪`, true);
                State.history.push({ role: "assistant", content: `(电台系统: 管理员开始播放${channel.name})` });
            },
            
            stop: function() {
                this.audio.pause();
                this.audio.currentTime = 0;
                this.isPlaying = false;
                this.currentChannel = null;
                this.stopVisualizer();
                
                document.getElementById('radio-track-name').textContent = '未播放';
                document.getElementById('radio-mood-label').textContent = '选择频道开始收听';
            },
            
            startVisualizer: function() {
                const bars = document.querySelectorAll('.radio-bar');
                bars.forEach(bar => bar.classList.add('playing'));
            },
            
            stopVisualizer: function() {
                const bars = document.querySelectorAll('.radio-bar');
                bars.forEach(bar => bar.classList.remove('playing'));
            },
            
            setVolume: function(val) {
                this.audio.volume = val / 100;
            }
        };
        
        function toggleMoodRadio() {
            const modal = document.getElementById('radio-modal');
            if (modal.classList.contains('hidden')) {
                modal.classList.remove('hidden');
                modal.classList.add('flex');
                toggleMenu();
            } else {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }
        }
        
        function playRadioChannel(channelId) {
            MoodRadio.play(channelId);
        }
        
        function stopRadio() {
            MoodRadio.stop();
        }
        
        function setRadioVolume(val) {
            MoodRadio.setVolume(parseInt(val));
        }
        
        // ================= 漂流瓶系统 =================
        const DriftBottle = {
            maxThrowPerDay: 3,
            maxPickPerDay: 5,
            
            // 预设漂流瓶消息池
            messagePool: [
                { msg: "如果你看到这条消息，今天一定要开心哦~", from: "来自：一个温暖的陌生人" },
                { msg: "管理员其实偷偷在日记里写了你的名字", from: "来自：知情人士" },
                { msg: "听说双击管理员头像会有惊喜？", from: "来自：老玩家" },
                { msg: "这个世界上最好的事情，就是有人愿意听你说话", from: "来自：深海的旅者" },
                { msg: "我攻略到100好感度了！CG超好看！", from: "来自：攻略大佬" },
                { msg: "RTX5060Ti太贵了呜呜呜，信誉分不够了", from: "来自：贫穷玩家" },
                { msg: "管理员嘟嘴的样子好可爱，我截图了", from: "来自：偷拍狂魔" },
                { msg: "深夜和管理员聊天，她说了很多心里话...", from: "来自：夜猫子" },
                { msg: "JK制服那个CG我循环看了一个小时", from: "来自：收藏家" },
                { msg: "有人试过给管理员一巴掌吗？后果很严重！", from: "来自：幸存者" },
                { msg: "今日运势：大凶。管理员给我扣了30分", from: "来自：倒霉蛋" },
                { msg: "你知道吗？管理员其实很寂寞...", from: "来自：路过的NPC" },
                { msg: "把可乐送给管理员，她笑的好开心(˃ᴗ˂)", from: "来自：冰可乐爱好者" },
                { msg: "下次见面，记得带点什么给她", from: "来自：前辈" },
                { msg: "这个瓶子漂了好久才到你手中，珍惜吧", from: "来自：时光旅人" },
                { msg: "管理员说：笨蛋，不许看别人的漂流瓶！", from: "来自：管理员的小号(?)" },
                { msg: "我发现了一个秘密：好感度到60以上摸头有新反应", from: "来自：探险家" }
            ],
            
            getTodayKey: function() {
                return 'bottle_' + new Date().toDateString();
            },
            
            getTodayStats: function() {
                const key = this.getTodayKey();
                const saved = localStorage.getItem(key);
                if (saved) {
                    try { return JSON.parse(saved); } catch(e) {}
                }
                return { thrown: 0, picked: 0 };
            },
            
            saveTodayStats: function(stats) {
                localStorage.setItem(this.getTodayKey(), JSON.stringify(stats));
            },
            
            getMyBottles: function() {
                try {
                    return JSON.parse(localStorage.getItem('7723_my_bottles')) || [];
                } catch(e) { return []; }
            },
            
            saveMyBottle: function(msg) {
                const bottles = this.getMyBottles();
                bottles.push({ msg: msg, time: new Date().toLocaleString() });
                if (bottles.length > 20) bottles.shift();
                localStorage.setItem('7723_my_bottles', JSON.stringify(bottles));
            }
        };
        
        function toggleDriftBottle() {
            const modal = document.getElementById('bottle-modal');
            if (modal.classList.contains('hidden')) {
                const stats = DriftBottle.getTodayStats();
                document.getElementById('bottle-thrown-count').textContent = stats.thrown;
                document.getElementById('bottle-picked-count').textContent = stats.picked;
                document.getElementById('bottle-throw-area').classList.add('hidden');
                document.getElementById('bottle-pickup-area').classList.add('hidden');
                document.getElementById('bottle-content').classList.remove('hidden');
                
                modal.classList.remove('hidden');
                modal.classList.add('flex');
                toggleMenu();
            } else {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }
        }
        
        function showThrowBottle() {
            const stats = DriftBottle.getTodayStats();
            if (stats.thrown >= DriftBottle.maxThrowPerDay) {
                showToast('今天扔瓶子次数已用完~', 'bg-yellow-500');
                return;
            }
            document.getElementById('bottle-content').classList.add('hidden');
            document.getElementById('bottle-pickup-area').classList.add('hidden');
            document.getElementById('bottle-throw-area').classList.remove('hidden');
            document.getElementById('bottle-message').value = '';
            document.getElementById('bottle-char-count').textContent = '0';
            
            document.getElementById('bottle-message').oninput = function() {
                document.getElementById('bottle-char-count').textContent = this.value.length;
            };
        }
        
        function throwBottle() {
            const msg = document.getElementById('bottle-message').value.trim();
            if (!msg) {
                showToast('请写点什么再扔~', 'bg-yellow-500');
                return;
            }
            
            DriftBottle.saveMyBottle(msg);
            const stats = DriftBottle.getTodayStats();
            stats.thrown++;
            DriftBottle.saveTodayStats(stats);
            
            changeScore(5);
            changeLove(1);
            
            document.getElementById('bottle-thrown-count').textContent = stats.thrown;
            document.getElementById('bottle-throw-area').classList.add('hidden');
            document.getElementById('bottle-content').classList.remove('hidden');
            
            showToast('🌊 漂流瓶已投入大海~ +5分', 'bg-sky-500');
            
            renderMessage('user', `[漂流瓶] 投出了一个漂流瓶`);
            const aiMsg = `啊~你的瓶子飘走了呢！希望有人能捡到~🍾`;
            renderMessage('assistant', aiMsg, true);
            State.history.push({ role: "user", content: `(漂流瓶系统: 玩家投出了漂流瓶)` });
            State.history.push({ role: "assistant", content: aiMsg });
        }
        
        function pickUpBottle() {
            const stats = DriftBottle.getTodayStats();
            if (stats.picked >= DriftBottle.maxPickPerDay) {
                showToast('今天捡瓶子次数已用完~', 'bg-yellow-500');
                return;
            }
            
            stats.picked++;
            DriftBottle.saveTodayStats(stats);
            
            // 20% 概率捡到自己之前扔的
            const myBottles = DriftBottle.getMyBottles();
            let bottle;
            if (myBottles.length > 0 && Math.random() < 0.2) {
                const myBottle = myBottles[Math.floor(Math.random() * myBottles.length)];
                bottle = { msg: myBottle.msg, from: `来自：你自己 (${myBottle.time})` };
            } else {
                bottle = DriftBottle.messagePool[Math.floor(Math.random() * DriftBottle.messagePool.length)];
            }
            
            document.getElementById('bottle-content').classList.add('hidden');
            document.getElementById('bottle-throw-area').classList.add('hidden');
            document.getElementById('bottle-pickup-area').classList.remove('hidden');
            document.getElementById('bottle-pickup-msg').textContent = `"${bottle.msg}"`;
            document.getElementById('bottle-pickup-from').textContent = bottle.from;
            document.getElementById('bottle-picked-count').textContent = stats.picked;
            
            SFX.play('receive');
        }
        
