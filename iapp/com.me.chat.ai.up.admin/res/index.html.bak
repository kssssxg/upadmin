<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>7723攻略计划 - 终极完整版 (含表情包)</title>
    <link href="res/font-awesome.min.css" rel="stylesheet">
    <script src="res/tailwind_cdn.js"></script>
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'app-bg': '#f2f2f7',
                        'bubble-me': '#95ec69',
                        'bubble-other': '#ffffff',
                        'primary': '#007aff',
                        'danger': '#ff3b30',
                        'love': '#ff69b4'
                    },
                    animation: {
                        'slide-in-up': 'slideInUp 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94) both',
                        'slide-in-left': 'slideInLeft 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94) both',
                        'slide-in-right': 'slideInRight 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94) both',
                        'pulse-slow': 'pulse 2s infinite',
                        'slide-down-toast': 'slideDownToast 0.5s cubic-bezier(0.68, -0.55, 0.27, 1.55) both',
                        'zoom-in': 'zoomIn 0.5s ease-out both'
                    },
                    keyframes: {
                        slideInUp: { '0%': { transform: 'translateY(20px)', opacity: '0' }, '100%': { transform: 'translateY(0)', opacity: '1' } },
                        slideInLeft: { '0%': { transform: 'translateX(-20px)', opacity: '0' }, '100%': { transform: 'translateX(0)', opacity: '1' } },
                        slideInRight: { '0%': { transform: 'translateX(20px)', opacity: '0' }, '100%': { transform: 'translateX(0)', opacity: '1' } },
                        slideDownToast: { '0%': { transform: 'translateY(-100%)', opacity: '0' }, '100%': { transform: 'translateY(0)', opacity: '1' } },
                        zoomIn: { '0%': { transform: 'scale(0.8)', opacity: '0' }, '100%': { transform: 'scale(1)', opacity: '1' } }
                    }
                }
            }
        }
    </script>
    <style>
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; transition: background-color 1s ease; }
        
        .choice-card:active { transform: scale(0.98); background-color: #f0f0f0; }
        
        /* 心情Toast容器 */
        #mood-toast-container {
            position: fixed;
            top: 70px;
            left: 0;
            right: 0;
            display: flex;
            justify-content: center;
            z-index: 40;
            pointer-events: none;
        }

        .typing-dot {
            display: inline-block; width: 6px; height: 6px; border-radius: 50%; background-color: #bbb;
            animation: typing 1.4s infinite ease-in-out both; margin: 0 2px;
        }
        .typing-dot:nth-child(1) { animation-delay: -0.32s; }
        .typing-dot:nth-child(2) { animation-delay: -0.16s; }
        @keyframes typing { 0%, 80%, 100% { transform: scale(0); } 40% { transform: scale(1); } }
        
        /* V2.0 飘字动画 */
        .floating-text {
            position: fixed;
            font-weight: bold;
            font-size: 1.5rem;
            pointer-events: none;
            z-index: 9999;
            text-shadow: 0 2px 4px rgba(0,0,0,0.3);
            animation: floatUp 2s ease-out forwards;
        }
        @keyframes floatUp {
            0% { transform: translateY(0) scale(1); opacity: 1; }
            100% { transform: translateY(-100px) scale(1.2); opacity: 0; }
        }
        @keyframes radioBarAnim {
            0%, 100% { height: 15%; }
            50% { height: 90%; }
        }
        .radio-bar.playing {
            animation: radioBarAnim 0.8s ease-in-out infinite;
        }
        .radio-bar.playing:nth-child(1) { animation-delay: 0s; }
        .radio-bar.playing:nth-child(2) { animation-delay: 0.15s; }
        .radio-bar.playing:nth-child(3) { animation-delay: 0.3s; }
        .radio-bar.playing:nth-child(4) { animation-delay: 0.1s; }
        .radio-bar.playing:nth-child(5) { animation-delay: 0.25s; }
        .radio-bar.playing:nth-child(6) { animation-delay: 0.05s; }
        .radio-bar.playing:nth-child(7) { animation-delay: 0.2s; }
        .radio-bar.playing:nth-child(8) { animation-delay: 0.35s; }
    </style>
</head>
<body class="h-screen w-screen flex flex-col bg-app-bg overflow-hidden safe-area-inset">

    <!-- 顶部导航 -->
    <div class="h-[60px] bg-white/30 backdrop-blur-md border-b border-white/20 flex items-center justify-between px-4 z-50 shadow-sm flex-shrink-0 transition-colors">
        <div class="flex items-center gap-3">
            <div class="relative cursor-pointer transition-transform active:scale-95" onclick="toggleMenu()">
                <img id="admin-avatar" src="" class="w-10 h-10 rounded-lg border border-white/50 object-cover shadow-sm transition-all duration-300">
                <div class="absolute -bottom-0.5 -right-0.5 w-3.5 h-3.5 bg-green-500 rounded-full border-2 border-white animate-pulse-slow"></div>
            </div>
            <div class="flex flex-col">
                <h1 class="font-bold text-gray-900 text-base leading-tight drop-shadow-sm">UP资源管理员</h1>
                <div class="flex items-center gap-1.5">
                    <span class="w-2 h-2 rounded-full bg-green-500"></span>
                    <p class="text-[10px] text-gray-600 font-medium">信誉分: <span id="score-val" class="font-bold text-primary">100</span></p>
                </div>
            </div>
        </div>
        <div class="flex items-center gap-4 text-gray-600">
            <button class="p-2 hover:bg-black/5 rounded-full transition-colors"><i class="fas fa-phone"></i></button>
            <button class="p-2 hover:bg-black/5 rounded-full transition-colors" onclick="toggleMenu()"><i class="fas fa-ellipsis-v"></i></button>
        </div>
    </div>

    <!-- 心情 Toast 容器 -->
    <div id="mood-toast-container"></div>

    <!-- 菜单 -->
    <div id="menu" class="hidden absolute top-16 right-3 w-72 bg-white/95 backdrop-blur-xl shadow-2xl rounded-2xl z-50 border border-gray-200/50 animate-slide-in-up origin-top-right transform transition-all max-h-[80vh] overflow-y-auto flex flex-col">
        <div class="p-3 space-y-2 flex-shrink-0">
            <button id="change-avatar-btn" class="w-full text-left px-4 py-3 text-sm text-gray-700 hover:bg-gray-100 rounded-xl flex items-center transition-colors shadow-sm bg-white border border-gray-100">
                <div class="w-8 h-8 rounded-full bg-pink-100 text-pink-500 flex items-center justify-center mr-3"><i class="fas fa-magic"></i></div>
                <span id="avatar-btn-text">切换人设 (娘化/原版)</span>
            </button>
            <button onclick="toggleVoice()" class="w-full text-left px-4 py-3 text-sm text-gray-700 hover:bg-gray-100 rounded-xl flex items-center transition-colors shadow-sm bg-white border border-gray-100">
    <div id="voice-icon-box" class="w-8 h-8 rounded-full bg-gray-100 text-gray-400 flex items-center justify-center mr-3 transition-colors">
        <i id="voice-icon" class="fas fa-volume-mute"></i>
    </div>
    <span id="voice-text">开启语音 (TTS)</span>
</button>
            <button onclick="toggleShop()" class="w-full text-left px-4 py-3 text-sm text-yellow-600 hover:bg-yellow-50 rounded-xl flex items-center transition-colors shadow-sm bg-white border border-gray-100">
                <div class="w-8 h-8 rounded-full bg-yellow-100 text-yellow-500 flex items-center justify-center mr-3"><i class="fas fa-gift"></i></div>
                <span>送礼</span>
            </button>
            <button onclick="toggleInventory()" class="w-full text-left px-4 py-3 text-sm text-blue-600 hover:bg-blue-50 rounded-xl flex items-center transition-colors shadow-sm bg-white border border-gray-100">
                <div class="w-8 h-8 rounded-full bg-blue-100 text-blue-500 flex items-center justify-center mr-3"><i class="fas fa-briefcase"></i></div>
                <span>背包</span>
            </button>
            <button onclick="toggleGallery()" class="w-full text-left px-4 py-3 text-sm text-pink-600 hover:bg-pink-50 rounded-xl flex items-center transition-colors shadow-sm bg-white border border-gray-100">
                <div class="w-8 h-8 rounded-full bg-pink-100 text-pink-500 flex items-center justify-center mr-3"><i class="fas fa-images"></i></div>
                <span>回忆相册</span>
            </button>
            <button onclick="toggleGames()" class="w-full text-left px-4 py-3 text-sm text-green-600 hover:bg-green-50 rounded-xl flex items-center transition-colors shadow-sm bg-white border border-gray-100">
                <div class="w-8 h-8 rounded-full bg-green-100 text-green-500 flex items-center justify-center mr-3"><i class="fas fa-gamepad"></i></div>
                <span>🎮 娱乐中心</span>
            </button>
            <button onclick="dailyCheckIn()" class="w-full text-left px-4 py-3 text-sm text-orange-600 hover:bg-orange-50 rounded-xl flex items-center transition-colors shadow-sm bg-white border border-gray-100">
                <div class="w-8 h-8 rounded-full bg-orange-100 text-orange-500 flex items-center justify-center mr-3"><i class="fas fa-calendar-check"></i></div>
                <span>📅 每日签到</span>
            </button>
            <button onclick="toggleAchievements()" class="w-full text-left px-4 py-3 text-sm text-purple-600 hover:bg-purple-50 rounded-xl flex items-center transition-colors shadow-sm bg-white border border-gray-100">
                <div class="w-8 h-8 rounded-full bg-purple-100 text-purple-500 flex items-center justify-center mr-3"><i class="fas fa-trophy"></i></div>
                <span>成就</span>
            </button>
            <button onclick="toggleTasks()" class="w-full text-left px-4 py-3 text-sm text-emerald-600 hover:bg-emerald-50 rounded-xl flex items-center transition-colors shadow-sm bg-white border border-gray-100">
                <div class="w-8 h-8 rounded-full bg-emerald-100 text-emerald-500 flex items-center justify-center mr-3"><i class="fas fa-tasks"></i></div>
                <span>每日任务</span>
            </button>
            <button onclick="toggleBackground()" class="w-full text-left px-4 py-3 text-sm text-fuchsia-600 hover:bg-fuchsia-50 rounded-xl flex items-center transition-colors shadow-sm bg-white border border-gray-100">
                <div class="w-8 h-8 rounded-full bg-fuchsia-100 text-fuchsia-500 flex items-center justify-center mr-3"><i class="fas fa-palette"></i></div>
                <span>聊天背景</span>
            </button>
            <button onclick="toggleMoodRadio()" class="w-full text-left px-4 py-3 text-sm text-cyan-600 hover:bg-cyan-50 rounded-xl flex items-center transition-colors shadow-sm bg-white border border-gray-100">
                <div class="w-8 h-8 rounded-full bg-cyan-100 text-cyan-500 flex items-center justify-center mr-3"><i class="fas fa-music"></i></div>
                <span>🎵 心情电台</span>
            </button>
            <button onclick="toggleDriftBottle()" class="w-full text-left px-4 py-3 text-sm text-teal-600 hover:bg-teal-50 rounded-xl flex items-center transition-colors shadow-sm bg-white border border-gray-100">
                <div class="w-8 h-8 rounded-full bg-teal-100 text-teal-500 flex items-center justify-center mr-3"><i class="fas fa-bottle-water"></i></div>
                <span>💌 漂流瓶</span>
            </button>
            <button onclick="toggleDiary()" class="w-full text-left px-4 py-3 text-sm text-indigo-600 hover:bg-indigo-50 rounded-xl flex items-center transition-colors shadow-sm bg-white border border-gray-100">
                <div class="w-8 h-8 rounded-full bg-indigo-100 text-indigo-500 flex items-center justify-center mr-3"><i class="fas fa-book-open"></i></div>
                <span>🔮 管理员日记</span>
            </button>
            <button onclick="toggleFortune()" class="w-full text-left px-4 py-3 text-sm text-violet-600 hover:bg-violet-50 rounded-xl flex items-center transition-colors shadow-sm bg-white border border-gray-100">
                <div class="w-8 h-8 rounded-full bg-violet-100 text-violet-500 flex items-center justify-center mr-3"><i class="fas fa-star"></i></div>
                <span>🎭 今日占卜</span>
            </button>
            <button onclick="toggleTruthDare()" class="w-full text-left px-4 py-3 text-sm text-rose-600 hover:bg-rose-50 rounded-xl flex items-center transition-colors shadow-sm bg-white border border-gray-100">
                <div class="w-8 h-8 rounded-full bg-rose-100 text-rose-500 flex items-center justify-center mr-3"><i class="fas fa-heart"></i></div>
                <span>🎤 真心话大冒险</span>
            </button>
            <button onclick="togglePet()" class="w-full text-left px-4 py-3 text-sm text-amber-600 hover:bg-amber-50 rounded-xl flex items-center transition-colors shadow-sm bg-white border border-gray-100">
                <div class="w-8 h-8 rounded-full bg-amber-100 text-amber-500 flex items-center justify-center mr-3"><i class="fas fa-paw"></i></div>
                <span>🐾 共养宠物</span>
            </button>
            <button onclick="clearHistory()" class="w-full text-left px-4 py-3 text-sm text-red-600 hover:bg-red-50 rounded-xl flex items-center transition-colors shadow-sm bg-white border border-gray-100">
                <div class="w-8 h-8 rounded-full bg-red-100 text-red-500 flex items-center justify-center mr-3"><i class="fas fa-trash-alt"></i></div>
                <span>重置剧情</span>
            </button>
        </div>
        
        <div class="h-px bg-gray-200 mx-3"></div>
        
        <div class="p-3 flex-1">
            <div class="mb-4">
                <p class="text-xs text-gray-400 font-bold mb-1 ml-1 uppercase">🎭 剧情生成模型</p>
                <select id="content-model-select" class="w-full bg-gray-50 border border-gray-200 text-gray-700 text-xs rounded-lg p-2.5 outline-none focus:ring-2 focus:ring-primary/20 appearance-none bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20width%3D%2220%22%20height%3D%2220%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M5%206l5%205%205-5%22%20stroke%3D%22%23999%22%20stroke-width%3D%222%22%20fill%3D%22none%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%2F%3E%3C%2Fsvg%3E')] bg-no-repeat bg-[right_0.5rem_center] bg-[length:1.2em_1.2em]"></select>
            </div>
            <div>
                <p class="text-xs text-gray-400 font-bold mb-1 ml-1 uppercase">⚡ 选项生成模型</p>
                <select id="option-model-select" class="w-full bg-gray-50 border border-gray-200 text-gray-700 text-xs rounded-lg p-2.5 outline-none focus:ring-2 focus:ring-primary/20 appearance-none bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20width%3D%2220%22%20height%3D%2220%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M5%206l5%205%205-5%22%20stroke%3D%22%23999%22%20stroke-width%3D%222%22%20fill%3D%22none%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%2F%3E%3C%2Fsvg%3E')] bg-no-repeat bg-[right_0.5rem_center] bg-[length:1.2em_1.2em]"></select>
            </div>
        </div>
    </div>

    <!-- 聊天内容区 (Flex布局防遮挡) -->
    <div id="chat-container" class="flex-1 overflow-y-auto overflow-x-hidden p-4 relative transition-colors duration-1000 scroll-smooth">
        <div id="messages-area" class="flex flex-col gap-4 pb-4"></div>
        
        <div id="typing-bubble" class="hidden flex w-full mb-4 animate-slide-in-left">
            <img id="typing-avatar" src="" class="w-10 h-10 rounded-lg border border-gray-200 flex-shrink-0 mr-3 shadow-sm bg-white">
            <div class="bg-white/80 backdrop-blur-sm px-4 py-3 rounded-xl rounded-tl-none shadow-sm flex items-center gap-1 border border-white/50">
                <div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div>
            </div>
        </div>
        <div class="h-4"></div>
    </div>

    <!-- 底部操作区 (Flex-Shrink-0) -->
    <div class="bg-white/80 backdrop-blur-lg border-t border-gray-200 p-4 pb-8 z-40 shadow-[0_-4px_20px_rgba(0,0,0,0.05)] rounded-t-3xl transition-colors duration-500 flex-shrink-0 relative">
        <div class="text-center mb-3">
            <span id="action-title" class="text-xs font-bold text-gray-400 uppercase tracking-widest">等待回应...</span>
        </div>

        <div id="options-loading" class="hidden flex justify-center py-4">
            <i class="fas fa-circle-notch fa-spin text-primary text-2xl"></i>
        </div>

        <div id="options-area" class="flex flex-col gap-3"></div>
    </div>

    <!-- 违规遮罩 -->
    <div id="cg-overlay" class="fixed inset-0 bg-black z-[100] hidden flex-col items-center justify-center text-center p-8 animate-fade-in">
        <div class="w-24 h-24 rounded-full bg-red-600 flex items-center justify-center mb-6 animate-pulse">
            <i class="fas fa-ban text-5xl text-white"></i>
        </div>
        <h2 class="text-white text-3xl font-bold mb-2">审核拦截</h2>
        <p class="text-gray-400 text-sm">检测到敏感词或违规指令</p>
        <div class="mt-8 px-6 py-2 bg-red-900/50 rounded-full border border-red-500/30 text-red-400 font-mono">
            Error: NSFW_DETECTED
        </div>
    </div>

    <!-- 全屏礼物/CG展示层 -->
    <div id="full-cg-overlay" onclick="closeCg()" class="fixed inset-0 z-[150] bg-black/90 hidden flex-col items-center justify-center animate-zoom-in cursor-pointer">
        <img id="cg-image" src="" class="max-w-full max-h-screen object-contain shadow-2xl rounded-lg">
        <p class="text-white/50 text-xs mt-4 animate-pulse">点击任意处关闭</p>
    </div>

    <!-- 商城弹窗 -->
    <div id="shop-modal" class="fixed inset-0 z-[80] bg-black/50 hidden items-end sm:items-center justify-center animate-fade-in">
        <div class="bg-white w-full sm:w-96 rounded-t-2xl sm:rounded-2xl p-6 shadow-2xl transform transition-transform">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-lg font-bold text-gray-800">🎁 积分商城</h3>
                <button onclick="toggleShop()" class="text-gray-400 hover:text-gray-600"><i class="fas fa-times"></i></button>
            </div>
            <p class="text-xs text-gray-500 mb-4">消耗信誉分购买礼物，不仅能增加好感，还能改变管理员的心情哦~</p>
            
            <div class="grid grid-cols-2 gap-3" id="shop-items"></div>
        </div>
    </div>

    <!-- 成就弹窗 -->
    <div id="achievement-modal" class="fixed inset-0 z-[80] bg-black/50 hidden items-end sm:items-center justify-center animate-fade-in">
        <div class="bg-white w-full sm:w-[500px] rounded-t-2xl sm:rounded-2xl shadow-2xl transform transition-transform max-h-[80vh] flex flex-col">
            <div class="flex justify-between items-center p-6 pb-4 flex-shrink-0">
                <h3 class="text-lg font-bold text-gray-800">🏆 成就系统</h3>
                <button onclick="toggleAchievements()" class="text-gray-400 hover:text-gray-600"><i class="fas fa-times"></i></button>
            </div>
            <p class="text-xs text-gray-500 px-6 pb-3 flex-shrink-0">探索游戏，解锁全部成就！</p>
            
            <div class="overflow-y-auto px-6 pb-6 flex-1" id="achievement-list">
                <!-- 成就列表将动态生成 -->
            </div>
        </div>
    </div>

    <!-- 每日任务弹窗 -->
    <div id="tasks-modal" class="fixed inset-0 z-[80] bg-black/50 hidden items-end sm:items-center justify-center animate-fade-in">
        <div class="bg-white w-full sm:w-[500px] rounded-t-2xl sm:rounded-2xl shadow-2xl transform transition-transform max-h-[80vh] flex flex-col">
            <div class="flex justify-between items-center p-6 pb-4 flex-shrink-0">
                <h3 class="text-lg font-bold text-gray-800">📋 每日任务</h3>
                <button onclick="toggleTasks()" class="text-gray-400 hover:text-gray-600"><i class="fas fa-times"></i></button>
            </div>
            <p class="text-xs text-gray-500 px-6 pb-3 flex-shrink-0">完成任务获得奖励！每日任务每天刷新。</p>
            
            <div class="overflow-y-auto px-6 pb-6 flex-1">
                <div class="mb-4">
                    <h4 class="text-sm font-bold text-emerald-600 mb-2">📅 每日任务</h4>
                    <div id="daily-tasks-list" class="space-y-2">
                        <!-- 每日任务列表将动态生成 -->
                    </div>
                </div>
                <div>
                    <h4 class="text-sm font-bold text-purple-600 mb-2">🎯 隐藏成就</h4>
                    <div id="hidden-achievements-list" class="space-y-2">
                        <!-- 隐藏成就列表将动态生成 -->
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 聊天背景弹窗 -->
    <div id="background-modal" class="fixed inset-0 z-[80] bg-black/50 hidden items-end sm:items-center justify-center animate-fade-in">
        <div class="bg-white w-full sm:w-96 rounded-t-2xl sm:rounded-2xl p-6 shadow-2xl transform transition-transform max-h-[80vh] flex flex-col">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-lg font-bold text-gray-800">🎨 聊天背景</h3>
                <button onclick="toggleBackground()" class="text-gray-400 hover:text-gray-600"><i class="fas fa-times"></i></button>
            </div>
            <p class="text-xs text-gray-500 mb-4">选择一个喜欢的背景吧~</p>
            
            <div class="grid grid-cols-2 gap-3 overflow-y-auto" id="background-list">
                <!-- 背景列表将动态生成 -->
            </div>
        </div>
    </div>

    <!-- V2.0 背包弹窗 -->
    <div id="inventory-modal" class="fixed inset-0 z-[80] bg-black/50 hidden items-end sm:items-center justify-center animate-fade-in">
        <div class="bg-white w-full sm:w-96 rounded-t-2xl sm:rounded-2xl p-6 shadow-2xl transform transition-transform max-h-[80vh] flex flex-col">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-lg font-bold text-gray-800">💼 我的背包</h3>
                <button onclick="toggleInventory()" class="text-gray-400 hover:text-gray-600"><i class="fas fa-times"></i></button>
            </div>
            <p class="text-xs text-gray-500 mb-4">点击道具使用或赠送</p>
            
            <div class="grid grid-cols-3 gap-3 overflow-y-auto" id="inventory-items">
                <!-- 背包物品将动态生成 -->
