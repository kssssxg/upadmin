                toast.className = 'fixed top-20 left-1/2 transform -translate-x-1/2 bg-gradient-to-r from-purple-600 to-pink-600 text-white px-6 py-4 rounded-xl shadow-2xl z-[200] animate-slide-down-toast flex items-center gap-3 border-2 border-white/30';
