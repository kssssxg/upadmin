    <script>
        // ================= 菜单切换函数 (必须在顶部定义) =================
        function toggleMenu() { document.getElementById('menu').classList.toggle('hidden'); }
        
        // ================= 配置区 =================
        const CONFIG = {
            api: {
                url: 'https://192.140.173.130/v1/chat/completions',
                key: 'sk-V7RHnLUNX9drOZvjio9pi5V71dH4wKedNu0FFLzUB3awPZGu',
            },
            avatars: {
